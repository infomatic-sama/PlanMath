<UserControl x:Class="ProcessCalc.Vistas.VistaConjuntoNumerosEntrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" Width="Auto">
    <ScrollViewer x:Name="contenedor" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="encabezado" CanHorizontallyScroll="True" CanVerticallyScroll="True" AllowDrop="True" Grid.Row="0">
                <StackPanel x:Name="infoArchivo" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                        <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                    </Grid>
                </StackPanel>

                <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" VerticalContentAlignment="Center" Padding="10">Variable o vector de entrada</Label>

                    <CheckBox x:Name="opcionCantidadAgregarNumeros" Grid.Row="0" Grid.Column="2" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="opcionCantidadAgregarNumeros_Checked" Unchecked="opcionCantidadAgregarNumeros_Unchecked">Agregar cantidad de números como un número más en el vector</CheckBox>
                </Grid>



            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Button x:Name="vistaOpcionLista" Margin="10" Grid.Column="0" Grid.Row="0" Click="vistaOpcionLista_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/22.png" Height="24" Width="24" Grid.Column="0"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="vistaOpcionTexto" Margin="10" Grid.Column="1" Grid.Row="0" Click="vistaOpcionTexto_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/23.png" Height="24" Width="24" Grid.Column="0"></Image>
                    </Button.Content>
                </Button>

            </Grid>

            <WrapPanel Name="contenedorNumeros" Orientation="Horizontal" Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" />

            <StackPanel x:Name="textoNumeros" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="10" Orientation="Vertical" Visibility="Collapsed">
                <TextBlock>El separador entre textos de información y el número es el punto y coma. Cada línea es un número.<LineBreak/>Primero se escriben las cadenas de texto y luego el número, escritos de izquierda a derecha separados por punto y coma.<LineBreak/>Para escribir el siguiente número, se avanza a la siguiente línea del texto.</TextBlock>
                <TextBox x:Name="listaTextoNumeros" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="listaTextoNumeros_TextChanged"></TextBox>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
