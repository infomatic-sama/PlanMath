<UserControl xmlns:TextosInformacion="clr-namespace:ProcessCalc.Controles.TextosInformacion"  x:Class="ProcessCalc.Vistas.VistaTextosInformacionEntrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Vistas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" Width="Auto">
    <ScrollViewer x:Name="contenedor" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="encabezado" CanHorizontallyScroll="True" CanVerticallyScroll="True" AllowDrop="True" Grid.Row="0">
                <StackPanel x:Name="infoArchivo" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                        <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                    </Grid>
                </StackPanel>

                <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" VerticalContentAlignment="Center" Padding="10">Variable o vector entrada</Label>

                </Grid>



            </StackPanel>
            <StackPanel Orientation="Vertical" x:Name="contenedorTextos" Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Button x:Name="vistaOpcionLista" Margin="10" Grid.Column="0" Grid.Row="0" Click="vistaOpcionLista_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/22.png" Height="24" Width="24" Grid.Column="0"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="vistaOpcionTexto" Margin="10" Grid.Column="1" Grid.Row="0" Click="vistaOpcionTexto_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/23.png" Height="24" Width="24" Grid.Column="0"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="agregarConjuntoTextos" Margin="10" Grid.Column="2" Grid.Row="0" Click="agregarConjuntoTextos_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos7/Icono_03.png" Height="24" Width="24" Grid.Column="0"></Image>
                    </Button.Content>
                </Button>

            </Grid>
            
            <StackPanel x:Name="textoNumeros" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="10" Orientation="Vertical" Visibility="Collapsed">
                <TextBlock>El separador entre cadenas de texto es el punto y coma. Se escriben las cadenas de texto de izquierda a derecha.</TextBlock>
                <StackPanel Orientation="Vertical" x:Name="listaTextoNumeros"></StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
