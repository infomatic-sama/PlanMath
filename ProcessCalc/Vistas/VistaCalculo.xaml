<UserControl x:Class="ProcessCalc.Vistas.VistaCalculo"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProcessCalc"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800" Loaded="UserControl_Loaded">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
    <StackPanel Orientation="Vertical">        
        <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

                <StackPanel x:Name="encabezado" Grid.Row="0" Grid.ColumnSpan="2" CanHorizontallyScroll="True" CanVerticallyScroll="True" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition ></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                        <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                    </Grid>
                </StackPanel>
        </Grid>
        
            <Label Grid.Row="1" Grid.ColumnSpan="2" Padding="15" FontWeight="Bold" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrush}}">Descripción del archivo de cálculo:</Label>
            <TextBlock x:Name="descripcion" Grid.Row="2" Grid.ColumnSpan="2" TextWrapping="Wrap" MinHeight="70" Padding="15" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}" />
            <Label Padding="15" Grid.Row="3" Grid.ColumnSpan="2" FontWeight="Bold" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrush}}">Descripción de las variables o vectores de entradas:</Label>

            <TextBlock x:Name="entradas" Grid.Row="4" Grid.ColumnSpan="2" TextWrapping="Wrap" MinHeight="70" Padding="15" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}" ></TextBlock>
            <!--<ScrollViewer x:Name="contenedorEntradas" Grid.Row="5" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">-->
            <Grid Grid.Row="5" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid x:Name="calculos" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"></Grid>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="listaEntradas" Orientation="Horizontal" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ></WrapPanel>
                </ScrollViewer>
            </Grid>
        
            <Label Padding="15" Grid.Row="6" Grid.ColumnSpan="2" FontWeight="Bold" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrush}}">Descripción de las variables o vectores retornados:</Label>
            <TextBlock x:Name="resultados" Grid.Row="7" Grid.ColumnSpan="2" TextWrapping="Wrap" MinHeight="70" Padding="15" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}" ></TextBlock>
            <ScrollViewer Grid.Row="8" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <WrapPanel x:Name="listaResultados" Orientation="Horizontal" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ></WrapPanel>
            </ScrollViewer>
        </StackPanel>
    </ScrollViewer>
</UserControl>
