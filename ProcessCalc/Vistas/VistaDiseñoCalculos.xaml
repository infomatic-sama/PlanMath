<UserControl x:Class="ProcessCalc.Vistas.VistaDiseñoCalculos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             xmlns:vistas="clr-namespace:ProcessCalc.Vistas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel x:Name="encabezado" CanHorizontallyScroll="True" CanVerticallyScroll="True" Grid.Row="0" Grid.ColumnSpan="2">
            <StackPanel x:Name="infoArchivo" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition ></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                    <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                </Grid>
            </StackPanel>
        </StackPanel>

        <Grid x:Name="grillaContenedora" Grid.Column="1" Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="grillaHerramientas" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="btnAgregarCalculo" Grid.Column="0" Margin="10" Padding="10" Click="btnAgregarCalculo_Click">
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/33.png" Height="24" Width="24" Grid.Column="0"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center">Agregar</Label>
                        </Grid>
                    </Button.Content>
                </Button>
                <Button x:Name="btnQuitarCalculo" Grid.Column="1" Margin="10" Padding="10" Click="btnQuitarCalculo_Click">
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/32.png" Height="24" Width="24" Grid.Column="0"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center">Quitar</Label>
                        </Grid>
                    </Button.Content>
                </Button>
                <Button x:Name="btnOperacionesCalculo" Grid.Column="2" Margin="10" Padding="10" Click="btnOperacionesCalculo_Click" >
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/29.png" Height="24" Width="24" Grid.Column="0"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center">Lógicas del cálculo</Label>
                        </Grid>
                    </Button.Content>
                </Button>

                <Button x:Name="btnInformacionCalculo" Grid.Column="3" Margin="10" Padding="10" Click="btnInformacionCalculo_Click" >
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/Iconos3/08.png" Height="24" Width="24" Grid.Column="0"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center">Información</Label>
                        </Grid>
                    </Button.Content>
                </Button>

                <Button x:Name="btnAgregarNota" Grid.Column="4" Margin="10" Padding="10" Click="btnAgregarNota_Click" >
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/Iconos3/09.png" Height="24" Width="24" Grid.Column="0"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center">Agregar nota</Label>
                        </Grid>
                    </Button.Content>
                </Button>
            </Grid>

            <ScrollViewer x:Name="contenedor" Grid.Row="1" HorizontalScrollBarVisibility="Auto"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"  >
                <Border BorderBrush="Black" BorderThickness="0,0,1,1" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">
                    <Border BorderBrush="Black" BorderThickness="1,1,0,0" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">

                        <Canvas x:Name="diagrama" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" AllowDrop="True" Drop="diagrama_Drop" MouseLeftButtonDown="diagrama_MouseLeftButtonDown" MouseMove="diagrama_MouseMove" MouseLeave="diagrama_MouseLeave">
                        
                    </Canvas>
                    </Border>
                </Border>
            </ScrollViewer>

            <ScrollViewer x:Name="contenedorInformacion" Grid.Row="2" Visibility="Collapsed" HorizontalScrollBarVisibility="Auto"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"  >
                <TextBox x:Name="infoElemento" Margin="10" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="infoElemento_TextChanged"></TextBox>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="textoBusquedaDiagrama" Grid.Column="0" Margin="10"></TextBox>
                <Button x:Name="buscarDiagrama" Grid.Column="1" Margin="5" Click="buscarDiagrama_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/06.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Grid x:Name="resultadosBusquedas" Grid.Column="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="siguienteResultado" Grid.Column="0" Margin="5" Click="siguienteResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/35.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                    <Button x:Name="anteriorResultado" Grid.Column="1" Margin="5" Click="anteriorResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/34.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                </Grid>
                <Button x:Name="limpiarBusqueda" Grid.Column="3" Margin="5" Click="limpiarBusqueda_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/07.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>
            
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0">Área de pizarra:</TextBlock>
                <Button x:Name="aumentarArea" Grid.Column="1" Margin="5" Click="aumentarArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/04.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirArea" Grid.Column="2" Margin="5" Click="disminuirArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/05.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="ajustarTamañoPizarra" Grid.Column="3" Margin="5" Click="ajustarTamañoPizarra_Click">Ajustar tamaño</Button>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*"></ColumnDefinition>
                    <ColumnDefinition Width="0.8*"></ColumnDefinition>
                    <ColumnDefinition Width="0.4*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0" Grid.RowSpan="2">Zoom:</TextBlock>
                <TextBox x:Name="zoom" Margin="10" Grid.Column="1" Grid.RowSpan="2" Padding="15,0,15,0" TextAlignment="Center" TextChanged="zoom_TextChanged">100</TextBox>
                <Label Margin="5" Grid.Column="2">%</Label>
                <Button x:Name="zoomNormal" Grid.Column="3" Margin="10" Click="zoomNormal_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/01.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="aumentarZoom" Grid.Column="4" Margin="10" Click="aumentarZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/02.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirZoom" Grid.Column="5" Margin="10" Click="disminuirZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/03.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

        </Grid>
        </Grid>
</UserControl>
