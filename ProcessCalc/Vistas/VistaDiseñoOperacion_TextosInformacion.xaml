<UserControl x:Class="ProcessCalc.Vistas.VistaDiseñoOperacion_TextosInformacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Vistas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel x:Name="encabezado" CanHorizontallyScroll="True" CanVerticallyScroll="True" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition ></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                    <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="infoOperacion" Orientation="Horizontal" CanHorizontallyScroll="True" CanVerticallyScroll="True"  Grid.Row="1" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Label x:Name="nombreCalculo" FontSize="15">Nombre Calculo</Label>
                <Label x:Name="nombreOperacion" FontSize="15">Nombre Variable o Vector</Label>
            </StackPanel>

            <StackPanel x:Name="infoTextosInformacion" Orientation="Horizontal" CanHorizontallyScroll="True" CanVerticallyScroll="True"  Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Label x:Name="nombreDefinicionTextosInformacion" FontSize="15">Nombre Definición</Label>
            </StackPanel>

            <Grid Grid.Row="3" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnDefinirRelaciones_TextosInformacion" Grid.Column="0" Grid.Row="0" Margin="10" Padding="5" HorizontalContentAlignment="Center" Click="btnDefinirRelaciones_TextosInformacion_Click">
                    <TextBlock TextAlignment="Center">Definir lógicas de asignaciones
                            <LineBreak></LineBreak> de cadenas de texto</TextBlock>
                </Button>

                <Button x:Name="btnQuitarRelaciones_TextosInformacion" Grid.Column="1" Grid.Row="0" Margin="10" Padding="5" HorizontalContentAlignment="Center" Click="btnQuitarRelaciones_TextosInformacion_Click">
                    <TextBlock TextAlignment="Center">Quitar definición lógicas de asignaciones
                            <LineBreak></LineBreak> de cadenas de texto</TextBlock>
                </Button>
            </Grid>
        </Grid>

        <ScrollViewer x:Name="contenedor" Grid.Column="1" Grid.Row="1" HorizontalScrollBarVisibility="Auto"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" >
            <Border BorderBrush="Black" BorderThickness="0,0,1,1" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">
                <Border BorderBrush="Black" BorderThickness="1,1,0,0" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">
                    <Canvas x:Name="diagrama"  Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" MouseLeftButtonDown="diagrama_MouseLeftButtonDown"></Canvas>
                </Border>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="textoBusquedaDiagrama" Grid.Column="0" Margin="10"></TextBox>
                <Button x:Name="buscarDiagrama" Grid.Column="1" Margin="5" Click="buscarDiagrama_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/06.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Grid x:Name="resultadosBusquedas" Grid.Column="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="siguienteResultado" Grid.Column="0" Margin="5" Click="siguienteResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/35.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                    <Button x:Name="anteriorResultado" Grid.Column="1" Margin="5" Click="anteriorResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/34.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                </Grid>
                <Button x:Name="limpiarBusqueda" Grid.Column="3" Margin="5" Click="limpiarBusqueda_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/07.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0" Grid.RowSpan="2">Área de pizarra:</TextBlock>
                <Button x:Name="aumentarArea" Grid.Column="1" Margin="5" Click="aumentarArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/04.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirArea" Grid.Column="2" Margin="5" Click="disminuirArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/05.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="ajustarTamañoPizarra" Grid.Column="3" Margin="5" Click="ajustarTamañoPizarra_Click">Ajustar tamaño</Button>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*"></ColumnDefinition>
                    <ColumnDefinition Width="0.8*"></ColumnDefinition>
                    <ColumnDefinition Width="0.4*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0" Grid.RowSpan="2">Zoom:</TextBlock>
                <TextBox x:Name="zoom" Margin="10" Grid.Column="1" Grid.RowSpan="2" Padding="15,0,15,0" TextAlignment="Center" TextChanged="zoom_TextChanged">100</TextBox>
                <Label Margin="5" Grid.Column="2">%</Label>
                <Button x:Name="zoomNormal" Grid.Column="3" Margin="10" Click="zoomNormal_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/01.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="aumentarZoom" Grid.Column="4" Margin="10" Click="aumentarZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/02.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirZoom" Grid.Column="5" Margin="10" Click="disminuirZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/03.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
