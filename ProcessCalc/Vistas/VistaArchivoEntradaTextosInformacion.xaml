<UserControl x:Class="ProcessCalc.Vistas.VistaArchivoEntradaTextosInformacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Vistas"
             mc:Ignorable="d" 
             xmlns:localEntidades="clr-namespace:ProcessCalc.Entidades"
             d:DesignHeight="450" d:DesignWidth="1400" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <localEntidades:MaxHeightConverter x:Name="MaxHeightValue" x:Key="MaxHeightValue" />
    </UserControl.Resources>
    <Grid AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="infoArchivo" Grid.Row="0" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition ></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" Grid.Column="0" CanContentScroll="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">

                    <Grid x:Name="grillaContenedor"  Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <Grid Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10" Padding="5" Grid.ColumnSpan="2">Los archivos agregados a esta lista se leerán (y se realizarán las lógicas de búsquedas) en el orden establecido:</TextBlock>

                            <Button x:Name="agregarArchivoLista" Grid.Row="1" Grid.Column="0" Margin="10" MaxWidth="150" Padding="5" Click="agregarArchivoLista_Click">
                                <Button.Content>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        </Grid.ColumnDefinitions>
                                        <Image Source="/ProcessCalc;component/Imagenes/Iconos12/icono_nuevo_01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                        <Label Grid.Column="1" VerticalAlignment="Center">Agregar archivo</Label>
                                    </Grid>
                                </Button.Content>
                            </Button>

                            <StackPanel x:Name="listaArchivos" Grid.Column="1" Grid.Row="1" CanHorizontallyScroll="True" Orientation="Horizontal" >

                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" VerticalContentAlignment="Center" Padding="10">Variable o vector de entrada</Label>

                            <Label Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">Realizar las lógicas de búsquedas del archivo en:</Label>
                            <RadioButton x:Name="opcionMismaLectura" Grid.Row="0" Grid.Column="2" Margin="10" VerticalAlignment="Center" Checked="opcionMismaLectura_Checked">La misma lectura.</RadioButton>
                            <RadioButton x:Name="opcionLecturasDistintas" Grid.Row="0" Grid.Column="3" Margin="10" VerticalAlignment="Center" Checked="opcionLecturasDistintas_Checked">Lecturas distintas.</RadioButton>

                            <CheckBox x:Name="opcionUtilizarTextosInformacionUnicos" Margin="10" Grid.Row="0" Grid.Column="4" VerticalContentAlignment="Center" Checked="opcionUtilizarTextosInformacionUnicos_Checked" Unchecked="opcionUtilizarTextosInformacionUnicos_Unchecked">Utilizar cadenas de texto sin repetición</CheckBox>

                        </Grid>

                    </Grid>
                </ScrollViewer>
                
                <Grid x:Name="grillaLecturaArchivo" Visibility="Collapsed" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.MaxHeight>
                        <Binding Converter="{StaticResource MaxHeightValue}" ElementName="grillaContenedor" Path="ActualHeight" />
                    </Grid.MaxHeight>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Grid  Grid.Row="0" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition ></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="10">La aplicación procesará el archivo y buscará las cadenas de texto en su contenido.</TextBlock>

                    <TextBlock x:Name="rutaArchivoContenido" Visibility="Collapsed" Margin="10" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"></TextBlock>
                    <ComboBox x:Name="rutasArchivosContenido" Visibility="Collapsed" Margin="10" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"></ComboBox>
                        
                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="10" VerticalAlignment="Center">Texto en el contenido:</TextBlock>
                        <Button x:Name="btnObtenerTexto" Grid.Column="1" Grid.Row="2" Margin="10" Padding="5" Click="btnObtenerTexto_Click" >Obtener el texto</Button>
                        <Button x:Name="BuscarNumeros" Grid.Row="2" Grid.Column="2" Margin="10" Padding="5" Click="BuscarNumeros_Click">Buscar números</Button>
                        <StackPanel x:Name="BusquedaNumeros" Grid.Column="3" Grid.Row="2" Orientation="Horizontal" Visibility="Collapsed">
                            <Button x:Name="NumeroSiguiente" Margin="10" Padding="5" Click="NumeroSiguiente_Click">Número siguiente</Button>
                            <Button x:Name="NumeroAnterior" Margin="10" Padding="5" Click="NumeroAnterior_Click">Número anterior</Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="contenidoTexto" IsInactiveSelectionHighlightEnabled="True"  Margin="10" FontSize="16" TextWrapping="Wrap" IsReadOnly="True"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
            
        <Grid Grid.Row="3" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                <Button x:Name="agregarBusqueda" Margin="10" Padding="10" Click="agregarBusqueda_Click">Agregar nueva lógica de búsqueda</Button>
            </StackPanel>


            <ScrollViewer  Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <StackPanel x:Name="busquedas"></StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" Grid.Column="1" x:Name="contenedorBusqueda" ></Grid>
        </Grid>
    </Grid>
</UserControl>
