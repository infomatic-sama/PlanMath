<UserControl x:Class="ProcessCalc.Vistas.VistaURLEntradaNumero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Vistas" xmlns:controles="clr-namespace:ProcessCalc.Controles"
             xmlns:localEntidades="clr-namespace:ProcessCalc.Entidades"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="1500" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <localEntidades:MaxWidthConverter x:Name="MaxWidthValue" x:Key="MaxWidthValue" />
    </UserControl.Resources>
    <Grid x:Name="contenedor">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.6*"></RowDefinition>
                <RowDefinition Height="1*"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

            <Grid x:Name="encabezado" Grid.Row="0" Grid.Column="0" AllowDrop="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="infoArchivo" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition ></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                    <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
                </Grid>
            </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                        <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" Grid.ColumnSpan="3" VerticalContentAlignment="Center" Padding="10">Variable o vector de entrada</Label>

                        <Button x:Name="configurarEscribirURL" Margin="10" Padding="5" Grid.Column="0" Grid.Row="1" Width="150" Click="configurarEscribirURL_Click">Definir configuración</Button>
                        <TextBlock x:Name="etiquetaDefinicionEscribirURL" Margin="10" Grid.Column="1" Grid.Row="1" ></TextBlock>

                        <Label x:Name="lblURL" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Center" VerticalContentAlignment="Center">Dirección de Internet:</Label>
                        <TextBox x:Name="txtURL" Grid.Row="2" Grid.Column="1" Margin="10" Grid.ColumnSpan="3" TextChanged="txtURL_TextChanged"></TextBox>
                        <Button x:Name="btnMostrarOcultarParametros" Grid.Column="2" Grid.Row="1" Margin="10" Padding="5" Click="btnMostrarOcultarParametros_Click" >Mostrar parámetros</Button>
                        <Button x:Name="btnDefinirHeaders" Grid.Column="3" Grid.Row="1" Margin="10" Padding="5" Click="btnDefinirHeaders_Click">Definir headers</Button>

                        <Button x:Name="btnDefinirTextosInformacionFijos" Grid.Column="3" Grid.Row="0" Margin="10" Padding="5" Width="200" Click="btnDefinirTextosInformacionFijos_Click" >
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                                </Grid>
                            </Button.Content>
                        </Button>
                    </Grid>
                </ScrollViewer>

            </Grid>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition ></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="1*"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <Grid Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="opcionBuscarTexto" Grid.Row="0" Grid.Column="0" Margin="10" Padding="5" Click="opcionBuscarTexto_Click">Encontrar un texto y obtener el número</RadioButton>
                        <RadioButton x:Name="opcionBuscarTextoNveces" Grid.Row="0" Grid.Column="1" Margin="10" Padding="5" Click="opcionBuscarTextoNveces_Click">Encontrar un texto n veces y obtener el número</RadioButton>

                    </Grid>
                </ScrollViewer>

                <controles:TextoEnArchivo x:Name="busquedaNumero" Grid.Row="1" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" Visibility="Collapsed" AllowDrop="True"></controles:TextoEnArchivo>
                
               
            </Grid>

        <Grid  Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.MaxWidth>
                <Binding Converter="{StaticResource MaxWidthValue}" ElementName="contenedor" Path="ActualWidth" />
            </Grid.MaxWidth>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid  Grid.Row="0" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition ></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="10">La aplicación navegará al sitio de internet y buscará en el hipertexto de la página el número.</TextBlock>

                <TextBlock Grid.Column="0" Grid.Row="1" Margin="10" VerticalAlignment="Center">Hipertexto:</TextBlock>
                <Button x:Name="btnObtenerDeURL" Grid.Column="1" Grid.Row="1" Margin="10" Padding="5" Click="btnObtenerDeURL_Click" >Obtener de URL</Button>
                <Button x:Name="BuscarNumeros" Grid.Row="1" Grid.Column="2" Margin="10" Padding="5" Click="BuscarNumeros_Click">Buscar números</Button>
                <StackPanel x:Name="BusquedaNumeros" Grid.Column="3" Grid.Row="1" Orientation="Horizontal" Visibility="Collapsed">
                    <Button x:Name="NumeroSiguiente" Margin="10" Padding="5" Click="NumeroSiguiente_Click">Número siguiente</Button>
                    <Button x:Name="NumeroAnterior" Margin="10" Padding="5" Click="NumeroAnterior_Click">Número anterior</Button>
                </StackPanel>
            </Grid>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="contenidoURL" IsInactiveSelectionHighlightEnabled="True"  Margin="10" FontSize="16" TextWrapping="Wrap" IsReadOnly="True"/>
            </ScrollViewer>
        </Grid>

        <ScrollViewer x:Name="tituloParametros" Grid.Column="2" Grid.Row="1" Visibility="Collapsed"  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.MaxWidth>
                <Binding Converter="{StaticResource MaxWidthValue}" ElementName="contenedor" Path="ActualWidth" />
            </ScrollViewer.MaxWidth>
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" FontWeight="Bold" Margin="10">Datos a enviar a la URL:</TextBlock>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="enviarParametrosEnUrl" Margin="10" Grid.Column="0" Checked="enviarParametrosEnUrl_Checked" Unchecked="enviarParametrosEnUrl_Unchecked">Enviar los parametros en la url</CheckBox>
                    <CheckBox x:Name="enviarParametrosEnBody" Margin="10" Grid.Column="1" Checked="enviarParametrosEnBody_Checked" Unchecked="enviarParametrosEnBody_Unchecked">Enviar los parametros dentro de la navegación</CheckBox>
                </Grid>

                <TextBlock Grid.Row="2" FontWeight="Bold" Margin="10">Los datos a enviar como parametros se enviaran en formato Json.</TextBlock>

                <Grid x:Name="parametros" Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                </Grid>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
