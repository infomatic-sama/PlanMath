<UserControl x:Class="ProcessCalc.Vistas.VistaArchivoEntradaNumero"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc" xmlns:controles="clr-namespace:ProcessCalc.Controles"
             mc:Ignorable="d" 
             xmlns:localEntidades="clr-namespace:ProcessCalc.Entidades"
             d:DesignHeight="450" d:DesignWidth="1500" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <localEntidades:MaxHeightConverter x:Name="MaxHeightValue" x:Key="MaxHeightValue" />
    </UserControl.Resources>
    <Grid x:Name="encabezado" AllowDrop="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        
        <StackPanel x:Name="infoArchivo" Grid.Row="0" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition ></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
            </Grid>
        </StackPanel>

        <ScrollViewer  Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid x:Name="grillaContenedor" Grid.Row="0" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" VerticalContentAlignment="Center" Padding="10">Variable o vector de entrada</Label>
                    <CheckBox x:Name="opcionEntradaManual" Margin="10" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Checked="opcionEntradaManual_Checked" Unchecked="opcionEntradaManual_Unchecked">Abrir el archivo manualmente en la ejecución</CheckBox>

                    <Button x:Name="configurarSeleccionCarpetaArchivo" Margin="10" Padding="5" Grid.Column="0" Grid.Row="1" MaxWidth="150"  VerticalContentAlignment="Center" Click="configurarSeleccionCarpetaArchivo_Click">Definir configuración</Button>
                    <TextBlock x:Name="etiquetaDefinicionSeleccionArchivoCarpeta" Margin="10" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="4" VerticalAlignment="Center"></TextBlock>

                    <Button x:Name="btnCambiarArchivo" Grid.Column="1" Grid.Row="2" Margin="10" Padding="5" Width="200" Click="btnCambiarArchivo_Click">Seleccionar archivo y/o carpeta</Button>
                    <ComboBox x:Name="tipoArchivo" Grid.Column="0" Grid.Row="2" Margin="10" Width="Auto" SelectionChanged="tipoArchivo_SelectionChanged">
                        <ComboBoxItem Content="Equipo local" Uid="1"/>
                        <ComboBoxItem Content="Red local" Uid="2"/>
                        <!--<ComboBoxItem Content="Servidor FTP" Uid="3"/>-->
                        <ComboBoxItem Content="Internet" Uid="4"/>
                    </ComboBox>
                    <Label x:Name="lblRutaArchivo" Grid.Column="2" Grid.Row="2" VerticalContentAlignment="Center">Se obtendrá el número de la entrada, del archivo C:\Carpeta\SubCarpeta\Archivo.txt</Label>
                    <TextBox x:Name="rutaFTP" Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" VerticalContentAlignment="Center" Margin="10" Visibility="Collapsed" Width="Auto" TextChanged="rutaFTP_TextChanged"></TextBox>
                    <Button x:Name="configCredencialesFTP" Grid.Column="3" Grid.Row="2" Margin="10" Padding="5" Visibility="Collapsed" Click="configCredencialesFTP_Click">Usuario conexión</Button>

                    <Button x:Name="btnDefinirTextosInformacionFijos" Grid.Column="0" Grid.Row="3" Margin="10" Padding="5" Width="200" Click="btnDefinirTextosInformacionFijos_Click" >
                        <Button.Content>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                            </Grid>
                        </Button.Content>
                    </Button>

                    <Grid Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="opcionEsperarArchivo" Grid.Row="0" Grid.Column="0" Margin="10" Padding="5" VerticalContentAlignment="Center" VerticalAlignment="Center" Checked="opcionEsperarArchivo_Checked" Unchecked="opcionEsperarArchivo_Unchecked">Esperar al archivo si no está en la carpeta</CheckBox>

                        <Grid Grid.Row="0" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Padding="10">Tiempo de espera:</TextBlock>
                            <TextBox x:Name="cantidadTiempo" Grid.Column="1" Margin="10" MaxWidth="100" Width="100" TextChanged="cantidadTiempo_TextChanged"></TextBox>
                            <ComboBox x:Name="opcionCantidadTiempo" Grid.Column="2" Padding="5" Margin="10" SelectionChanged="opcionCantidadTiempo_SelectionChanged">
                                <ComboBoxItem Content="Segundos" IsSelected="True" Uid="1"/>
                                <ComboBoxItem Content="Minutos" Uid="2"/>
                                <ComboBoxItem Content="Horas" Uid="3"/>
                                <ComboBoxItem Content="Días" Uid="4"/>
                            </ComboBox>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid x:Name="panelArchivo" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.MaxHeight>
                        <Binding Converter="{StaticResource MaxHeightValue}" ElementName="grillaContenedor" Path="ActualHeight" />
                    </Grid.MaxHeight>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Grid  Grid.Row="0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition ></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="10">La aplicación procesará el archivo y buscará en el contenido del mismo, el número.</TextBlock>

                        <TextBlock Grid.Column="0" Grid.Row="1" Margin="10" VerticalAlignment="Center">Texto en el contenido:</TextBlock>
                        <Button x:Name="btnObtenerTexto" Grid.Column="1" Grid.Row="1" Margin="10" Padding="5" Click="btnObtenerTexto_Click" >Obtener el texto</Button>
                        <Button x:Name="BuscarNumeros" Grid.Row="1" Grid.Column="2" Margin="10" Padding="5" Click="BuscarNumeros_Click">Buscar números</Button>
                        <StackPanel x:Name="BusquedaNumeros" Grid.Column="3" Grid.Row="1" Orientation="Horizontal" Visibility="Collapsed">
                            <Button x:Name="NumeroSiguiente" Margin="10" Padding="5" Click="NumeroSiguiente_Click">Número siguiente</Button>
                            <Button x:Name="NumeroAnterior" Margin="10" Padding="5" Click="NumeroAnterior_Click">Número anterior</Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="contenidoTexto" IsInactiveSelectionHighlightEnabled="True"  Margin="10" FontSize="16" TextWrapping="Wrap" IsReadOnly="True"/>
                    </ScrollViewer>
                </Grid>

            </Grid>
        </ScrollViewer>

        <Grid x:Name="panelBusqueda" Grid.Row="2" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.ColumnSpan="2" Margin="10">Encontrar cadena de texto:</Label>
            <RadioButton x:Name="opcionBuscarTexto" Grid.Row="1" Grid.Column="0" Margin="10" Padding="5" Click="opcionBuscarTexto_Click">Encontrar una cadena de texto y obtener el número</RadioButton>
            <RadioButton x:Name="opcionBuscarTextoNveces" Grid.Row="1" Grid.Column="1" Margin="10" Padding="5" Click="opcionBuscarTextoNveces_Click">Encontrar una cadena de texto n veces y obtener el número</RadioButton>

        </Grid>
        <controles:TextoEnArchivo x:Name="busquedaNumero"  Grid.Row="3" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" Visibility="Collapsed" AllowDrop="True"></controles:TextoEnArchivo>
    </Grid>
</UserControl>
