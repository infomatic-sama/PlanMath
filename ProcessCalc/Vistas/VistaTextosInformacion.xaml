<UserControl x:Class="ProcessCalc.Vistas.VistaTextosInformacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Vistas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000" AllowDrop="True" Loaded="UserControl_Loaded" SizeChanged="UserControl_SizeChanged">
    <Grid Margin="10" AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition x:Name="fila" Height="1*" AllowDrop="True"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition x:Name="columna" Width="1*" AllowDrop="True"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0">
            <TextBlock FontSize="16">Mapa de lógicas de asignaciones de cadenas de texto</TextBlock>            
        </TextBlock>

        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnAgregarTextoInformacion" Grid.Column="0" Margin="10" Padding="10" Click="btnAgregarTextoInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/13.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Agregar definición</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnAgregarListaCadenasTexto" Grid.Column="1" Margin="10" Padding="10" Click="btnAgregarListaCadenasTexto_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos19/icono_pm.png" ></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Agregar lista de cadenas de texto</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnAgregarEntradaTextosInformacion" Grid.Column="2" Margin="10" Padding="10" Click="btnAgregarEntradaTextosInformacion_Click" >
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/13.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Agregar entrada</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnQuitarTextoInformacion" Grid.Column="3" Margin="10" Padding="10" Click="btnQuitarTextoInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/14.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Quitar</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnDefinicionSimple_RelacionesTextosInformacion" Grid.Column="4" Margin="10" Padding="10" Click="btnDefinicionSimple_RelacionesTextosInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/15.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Definición de lógica</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnDefinicionNormal_RelacionesTextosInformacion" Grid.Column="5" Margin="10" Padding="10" Click="btnDefinicionNormal_RelacionesTextosInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/16.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Definición de lógica interna</Label>
                    </Grid>
                </Button.Content>
            </Button>

            <Button x:Name="btnOperacion_RelacionesTextosInformacion" Grid.Column="6" Margin="10" Padding="10" Click="btnOperacion_RelacionesTextosInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Height="24" Width="24" Grid.Column="0" Source="/ProcessCalc;component/Imagenes/Iconos4/17.png"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center">Variable o vector relacionado</Label>
                    </Grid>
                </Button.Content>
            </Button>

        </Grid>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="contenedorEntradas" Grid.Row="0" Grid.Column="0" HorizontalScrollBarVisibility="Auto"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}" >
                <WrapPanel Name="entradas" Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="0" Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid x:Name="grillaCalculos" Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Margin="10">Cálculos</Label>
            </Grid>
            <ScrollViewer x:Name="contenedorCalculos" Grid.Row="1"  HorizontalScrollBarVisibility="Hidden"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"  >
                <Grid x:Name="calculos" ></Grid>
            </ScrollViewer>
        </Grid>

        <ScrollViewer x:Name="contenedor" Grid.Row="3" Grid.Column="1" AllowDrop="True" HorizontalScrollBarVisibility="Auto"  VerticalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Border BorderBrush="Black" BorderThickness="0,0,1,1" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">
                <Border BorderBrush="Black" BorderThickness="1,1,0,0" Width="{Binding ElementName=diagrama, Path=ActualWidth}" Height="{Binding ElementName=diagrama, Path=ActualHeight}">
                    <Canvas x:Name="diagrama" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" AllowDrop="True" MouseLeftButtonDown="diagrama_MouseLeftButtonDown" MouseMove="diagrama_MouseMove" Drop="diagrama_Drop" />
                </Border>
            </Border>
        </ScrollViewer>

        <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="textoBusquedaDiagrama" Grid.Column="0" Margin="10"></TextBox>
                <Button x:Name="buscarDiagrama" Grid.Column="1" Margin="5" Click="buscarDiagrama_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/06.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Grid x:Name="resultadosBusquedas" Grid.Column="2" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="siguienteResultado" Grid.Column="0" Margin="5" Click="siguienteResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/35.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                    <Button x:Name="anteriorResultado" Grid.Column="1" Margin="5" Click="anteriorResultado_Click" >
                        <Button.Content>
                            <Image Source="/ProcessCalc;component/Imagenes/34.png" Width="16" Height="16"></Image>
                        </Button.Content>
                    </Button>
                </Grid>
                <Button x:Name="limpiarBusqueda" Grid.Column="3" Margin="5" Click="limpiarBusqueda_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/07.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0" Grid.RowSpan="2">Área de pizarra:</TextBlock>
                <Button x:Name="aumentarArea" Grid.Column="1" Margin="5" Click="aumentarArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/04.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirArea" Grid.Column="2" Margin="5" Click="disminuirArea_Click" >
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/05.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="ajustarTamañoPizarra" Grid.Column="3" Margin="5" Click="ajustarTamañoPizarra_Click">Ajustar tamaño</Button>
            </Grid>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.7*"></ColumnDefinition>
                    <ColumnDefinition Width="0.8*"></ColumnDefinition>
                    <ColumnDefinition Width="0.4*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Grid.Column="0" Grid.RowSpan="2">Zoom:</TextBlock>
                <TextBox x:Name="zoom" Margin="10" Grid.Column="1" Grid.RowSpan="2" Padding="15,0,15,0" TextAlignment="Center" TextChanged="zoom_TextChanged">100</TextBox>
                <Label Margin="5" Grid.Column="2">%</Label>
                <Button x:Name="zoomNormal" Grid.Column="3" Margin="10" Click="zoomNormal_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/01.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="aumentarZoom" Grid.Column="4" Margin="10" Click="aumentarZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/02.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="disminuirZoom" Grid.Column="5" Margin="10" Click="disminuirZoom_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos3/03.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

        </Grid>
        
    </Grid>
</UserControl>
