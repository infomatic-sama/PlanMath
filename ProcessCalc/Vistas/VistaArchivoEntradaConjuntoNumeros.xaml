<UserControl x:Class="ProcessCalc.Vistas.VistaArchivoEntradaConjuntoNumeros"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc" xmlns:controles="clr-namespace:ProcessCalc.Controles"
             mc:Ignorable="d" 
             xmlns:localEntidades="clr-namespace:ProcessCalc.Entidades"
             d:DesignHeight="450" d:DesignWidth="1800" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <localEntidades:MaxHeightConverter x:Name="MaxHeightValue" x:Key="MaxHeightValue" />
    </UserControl.Resources>
    <Grid AllowDrop="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <StackPanel x:Name="infoArchivo" Grid.Row="0" Grid.Column="0" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                <Label x:Name="nombreArchivo" FontWeight="Bold" >NombreCalculo.pmcalc</Label>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition ></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnAbrirCarpeta" Grid.Column="1" Margin="5" Padding="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
                <Label x:Name="rutaArchivo" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Center" >C:\Carpeta\SubCarpeta\NombreCalculo.pmcalc</Label>
            </Grid>
        </StackPanel>

        <Grid x:Name="contenedor" Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

            <ScrollViewer Grid.Column="0" Grid.Row="0" CanContentScroll="True" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">

                <Grid x:Name="grillaContenedor" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <!--<Grid.MaxWidth>
                        <Binding Converter="{StaticResource MaxWidthValue}" ElementName="contenedor" Path="ActualWidth" />
                    </Grid.MaxWidth>-->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Column="0" Grid.Row="0" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Label x:Name="lblNombreEntrada" Grid.Column="0" Grid.Row="0" FontSize="15" VerticalContentAlignment="Center" Padding="10">Variable o vector de entrada</Label>
                        <CheckBox x:Name="opcionCantidadAgregarNumeros" Grid.Row="0" Grid.Column="1" Margin="10" HorizontalAlignment="Right" VerticalAlignment="Center" Checked="opcionCantidadAgregarNumeros_Checked" Unchecked="opcionCantidadAgregarNumeros_Unchecked">Utilizar cantidad de números en el vector</CheckBox>
                        <ComboBox x:Name="opcionUtilizacionCantidadAgregarNumeros" Grid.Row="0" Grid.Column="2" Margin="10" Width="300" HorizontalAlignment="Left" VerticalAlignment="Center" SelectionChanged="opcionUtilizacionCantidadAgregarNumeros_SelectionChanged">
                            <ComboBoxItem Content="Agregar cantidad de números como un número más en el vector" Uid="1"/>
                            <ComboBoxItem Content="Dejar la cantidad de números como el único número en el vector" Uid="2"/>
                        </ComboBox>
                    </Grid>


                    <Grid Grid.Column="0" Grid.Row="1" Grid.RowSpan="2" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="10" Padding="5" Grid.ColumnSpan="2">Los archivos agregados a esta lista se leerán (y se realizarán las lógicas de búsquedas) en el orden establecido:</TextBlock>

                        <Button x:Name="agregarArchivoLista" Grid.Row="1" Grid.Column="0" Margin="10" MaxWidth="150" Padding="5" Click="agregarArchivoLista_Click">
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/ProcessCalc;component/Imagenes/Iconos12/icono_nuevo_01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                    <Label Grid.Column="1" VerticalAlignment="Center">Agregar archivo</Label>
                                </Grid>
                            </Button.Content>
                        </Button>

                        <StackPanel x:Name="listaArchivos" Grid.Row="1" Grid.Column="1" CanHorizontallyScroll="True" Orientation="Horizontal" >

                        </StackPanel>
                    </Grid>


                    <Grid Grid.Column="0" Grid.Row="3" >
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnDefinirTextosInformacionFijos" Grid.Column="0" Grid.Row="0" Margin="10" Padding="5" Width="200" Click="btnDefinirTextosInformacionFijos_Click" >
                            <Button.Content>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                    <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                                </Grid>
                            </Button.Content>
                        </Button>

                        <TextBlock Grid.Column="1" Grid.Row="0" Margin="10" VerticalAlignment="Center">Lógica interna a realizar:</TextBlock>
                        <ComboBox x:Name="operacionInterna" Grid.Column="2" Grid.Row="0" Margin="10" VerticalAlignment="Center" SelectionChanged="operacionInterna_SelectionChanged">
                            <ComboBoxItem Content="Ninguna" Uid="0"/>
                            <ComboBoxItem Content="Suma" Uid="3"/>
                            <ComboBoxItem Content="Resta" Uid="4"/>
                            <ComboBoxItem Content="Multiplicación" Uid="5"/>
                            <ComboBoxItem Content="División" Uid="6"/>
                            <ComboBoxItem Content="Porcentaje" Uid="16"/>
                            <ComboBoxItem Content="Potencia" Uid="9"/>
                            <ComboBoxItem Content="Raíz" Uid="10"/>
                            <ComboBoxItem Content="Logaritmo" Uid="17"/>
                            <ComboBoxItem Content="Inverso" Uid="18"/>
                            <ComboBoxItem Content="Lógica de seleccionar números" Uid="11"/>
                            <ComboBoxItem Content="Lógica de limpiar datos" Uid="23"/>
                            <ComboBoxItem Content="Lógica de redondear números" Uid="24"/>                            
                        </ComboBox>

                        <ComboBox x:Name="opcionesElementosFijosInverso" Visibility="Collapsed" Margin="10" Grid.Column="3" Grid.Row="0" SelectionChanged="opcionesElementosFijosInverso_SelectionChanged">
                            <ComboBoxItem Content="Inverso de la suma y resta" Uid="2"/>
                            <ComboBoxItem Content="Inverso de la multiplicación y división" Uid="3"/>
                        </ComboBox>

                        <Grid  Grid.Column="4" Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            
                            <Button x:Name="btnDefinirTextosInformacionOperacionInterna" Grid.Column="0" Grid.Row="0" Margin="10" Padding="5" Width="230" Visibility="Collapsed" Click="btnDefinirTextosInformacionOperacionInterna_Click">Cadenas de texto de la variable o vector</Button>

                            <Button x:Name="botonOpcionLimpiarDatosOperacionInterna" Visibility="Collapsed" Margin="10" Grid.Row="0" Grid.Column="1" Click="botonOpcionLimpiarDatosOperacionInterna_Click">Opciones de lógica de limpieza</Button>

                            <Button x:Name="botonOpcionRedondearCantidadesOperacionInterna" Visibility="Collapsed" Margin="10" Grid.Row="0" Grid.Column="2" Click="botonOpcionRedondearCantidadesOperacionInterna_Click">Opciones de lógica de redondeo</Button>
                        </Grid>
                        

                        <Label Grid.Row="0" Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">Realizar las lógicas de búsquedas del archivo en:</Label>
                        <RadioButton x:Name="opcionMismaLectura" Grid.Row="0" Grid.Column="6" Margin="10" VerticalAlignment="Center" Checked="opcionMismaLectura_Checked">La misma lectura.</RadioButton>
                        <RadioButton x:Name="opcionLecturasDistintas" Grid.Row="0" Grid.Column="7" Margin="10" VerticalAlignment="Center" Checked="opcionLecturasDistintas_Checked">Lecturas distintas.</RadioButton>
                    </Grid>

                </Grid>

            </ScrollViewer>
            
            <Grid x:Name="grillaLecturaArchivo" Visibility="Collapsed" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
                    <Grid.MaxHeight>
                        <Binding Converter="{StaticResource MaxHeightValue}" ElementName="grillaContenedor" Path="ActualHeight" />
                    </Grid.MaxHeight>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Grid  Grid.Row="0" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition ></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" TextWrapping="Wrap" Margin="10">La aplicación procesará el archivo y buscará los números en su contenido.</TextBlock>

                    <TextBlock x:Name="rutaArchivoContenido" Visibility="Collapsed" Margin="10" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"></TextBlock>
                    <ComboBox x:Name="rutasArchivosContenido" Visibility="Collapsed" Margin="10" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"></ComboBox>

                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="10" VerticalAlignment="Center">Texto en el contenido:</TextBlock>
                        <Button x:Name="btnObtenerTexto" Grid.Column="1" Grid.Row="2" Margin="10" Padding="5" Click="btnObtenerTexto_Click" >Obtener el texto</Button>
                        <Button x:Name="BuscarNumeros" Grid.Row="2" Grid.Column="2" Margin="10" Padding="5" Click="BuscarNumeros_Click">Buscar números</Button>
                        <StackPanel x:Name="BusquedaNumeros" Grid.Column="3" Grid.Row="2" Orientation="Horizontal" Visibility="Collapsed">
                            <Button x:Name="NumeroSiguiente" Margin="10" Padding="5" Click="NumeroSiguiente_Click">Número siguiente</Button>
                            <Button x:Name="NumeroAnterior" Margin="10" Padding="5" Click="NumeroAnterior_Click">Número anterior</Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="contenidoTexto" IsInactiveSelectionHighlightEnabled="True"  Margin="10" FontSize="16" TextWrapping="Wrap" IsReadOnly="True"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Grid Grid.Row="3" Grid.Column="0">
                <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                <Button x:Name="agregarBusqueda" Margin="10" Padding="10" Click="agregarBusqueda_Click">Agregar nueva lógica de búsqueda</Button>
            </StackPanel>
            
                
                <ScrollViewer  Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="busquedas"></StackPanel>
                </ScrollViewer>

            <Grid Grid.Row="1" Grid.Column="1" x:Name="contenedorBusqueda" ></Grid>
                
            </Grid>
        </Grid>

</UserControl>
