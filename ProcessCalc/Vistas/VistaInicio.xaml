<UserControl x:Class="ProcessCalc.Vistas.VistaInicio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"></Border>
        <Border Grid.Row="1" Grid.ColumnSpan="3"></Border>
        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"></Border>
        <Border Grid.Row="3" Grid.ColumnSpan="3"></Border>

        <Image Grid.Row="0" Grid.Column="0" Margin="10,10,10,10" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/10.png"></Image>

        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition MaxWidth="200"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="textoArchivosAbiertos" Grid.Row="0" Margin="30,10,10,10" Grid.Column="0" FontSize="15" VerticalAlignment="Center">Archivos abiertos recientemente</TextBlock>
            <TextBlock Grid.Row="0" Margin="10,10,10,10" Grid.Column="1" FontSize="15" VerticalAlignment="Center">Buscar:</TextBlock>
            <TextBox x:Name="textoBusquedaArchivosAbiertos" Grid.Row="0" Margin="10,10,10,10" Grid.Column="2" FontSize="15" VerticalAlignment="Center"></TextBox>
            <Button x:Name="buscarArchivosAbiertos" Grid.Row="0" Margin="10,10,10,10" Grid.Column="3" FontSize="15" VerticalAlignment="Center" Click="buscarArchivosAbiertos_Click">Buscar</Button>
        </Grid>
        <ScrollViewer Grid.Row="1" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <StackPanel x:Name="listaArchivosRecientes" Orientation="Vertical"></StackPanel>
        </ScrollViewer>
        <Button x:Name="btnVaciarArchivosRecientes" Grid.Row="0" Grid.Column="2" Margin="10" Padding="5" Click="btnVaciarArchivosRecientes_Click">
            <Button.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Image Source="/ProcessCalc;component/Imagenes/36.png" Grid.Column="0" Width="24" Height="24"></Image>
                    <Label Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">Vaciar</Label>
                </Grid>
            </Button.Content>
        </Button>

        <Image Grid.Row="2" Grid.Column="0" Margin="10,10,10,10" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/11.png"></Image>

        <Grid Grid.Row="2" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition MaxWidth="200"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock x:Name="textoEjecucionesRecientes" Grid.Row="0" Grid.Column="0" Margin="30,10,10,10" FontSize="15" VerticalAlignment="Center">Ejecuciones de cálculos recientes</TextBlock>
            <TextBlock Grid.Row="0" Margin="10,10,10,10" Grid.Column="1" FontSize="15" VerticalAlignment="Center">Buscar:</TextBlock>
            <TextBox x:Name="textoBusquedaEjecucionesRecientes" Grid.Row="0" Margin="10,10,10,10" Grid.Column="2" FontSize="15" VerticalAlignment="Center"></TextBox>
            <Button x:Name="buscarEjecucionesRecientes" Grid.Row="0" Margin="10,10,10,10" Grid.Column="3" FontSize="15" VerticalAlignment="Center" Click="buscarEjecucionesRecientes_Click">Buscar</Button>
        </Grid>

        <ScrollViewer Grid.Row="3" Grid.ColumnSpan="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <StackPanel x:Name="listaEjecucionesRecientes" Orientation="Vertical"></StackPanel>
        </ScrollViewer>
        <Button x:Name="btnVaciarEjecucionesRecientes" Grid.Row="2" Grid.Column="2" Margin="10" Padding="5" Click="btnVaciarEjecucionesRecientes_Click">
            <Button.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Image Source="/ProcessCalc;component/Imagenes/36.png" Grid.Column="0" Width="24" Height="24"></Image>
                    <Label Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">Vaciar</Label>
                </Grid>
            </Button.Content>
        </Button>
        
    </Grid>
    
</UserControl>
