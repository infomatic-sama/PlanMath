<UserControl x:Class="ProcessCalc.Controles.Calculos.ToolTipElementoVisual"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.Calculos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" MaxWidth="3000" MaxHeight="500"
             Focusable="True" Background="{DynamicResource {x:Static SystemColors.InfoBrushKey}}" Padding="10">
    <ScrollViewer CanContentScroll="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="infoEstado" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Obteniendo y actualizando información...</TextBlock>
            <TextBlock x:Name="infoEntradaNoSeleccionada" Visibility="Collapsed" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">Entrada no seleccionada</TextBlock>

            <TextBlock x:Name="infoHora" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Visibility="Collapsed">Hora: 00:00</TextBlock>

            <Grid Grid.Row="2" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                
                <TextBlock x:Name="infoDigitacion" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Visibility="Collapsed">Esta información es de prueba, la entrada se digita en una ejecución normal.</TextBlock>

                <Button x:Name="botonDigitacion" Grid.Row="0" BorderThickness="1" BorderBrush="Black" Margin="2" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Click="botonDigitacion_Click" Visibility="Collapsed">Digitar información de prueba</Button>

                <TextBlock x:Name="infoSeleccionEntradas" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Visibility="Collapsed">Esta información es de prueba, este operador seleccionará las entradas elegidas manualmente.</TextBlock>

                <Button x:Name="botonSeleccionEntradas" Grid.Row="0" BorderThickness="2" BorderBrush="Black" Margin="2" Grid.Column="3" FontWeight="Bold" VerticalAlignment="Center" Click="botonSeleccionEntradas_Click" Visibility="Collapsed">Seleccionar entradas manualmente</Button>

                <TextBlock x:Name="infoSeleccionArchivosEntradas" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Visibility="Collapsed">Esta información es de prueba, los archivos de la entrada se seleccionan en una ejecución normal.</TextBlock>

                <StackPanel x:Name="botonesSeleccionArchivosEntradas" Grid.Row="0" Margin="2" Grid.Column="5" VerticalAlignment="Center" Visibility="Collapsed"></StackPanel>
            </Grid>

            <TextBlock x:Name="infoTextoEnPantalla" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Visibility="Collapsed">Texto en pantalla:</TextBlock>

            <ItemsControl x:Name="infoNumeros" Grid.Row="5" Visibility="Collapsed" Background="{x:Null}" ItemsSource="{Binding Grupos}">
                    <!-- Panel virtualizable -->
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel 
            IsVirtualizing="True"
            VirtualizationMode="Recycling" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:ClasificadorGrupo}">
                            <StackPanel Margin="0,4,0,8">
                                <!-- Encabezado del clasificador (1 solo TextBlock) -->
                                <TextBlock Text="{Binding Nombre}"
                     FontWeight="Bold"
                     Margin="2,0,2,4" />

                                <!-- Lista de números dentro del clasificador -->
                                <ItemsControl ItemsSource="{Binding Numeros}"
                    ScrollViewer.CanContentScroll="True"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    BorderThickness="0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <!-- Fila liviana sin Grid: un Wrap de Inlines -->
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type local:NumeroItem}">
                                            <TextBlock Margin="2">
                  <Run Text="{Binding Nombre}" FontWeight="Bold" />
                  <Run Text=" " />
                  <Run Text="{Binding Valor}" />
                  <Run Text=" " />
                  <Run Text="{Binding TextosPlano, Mode=OneWay}" FontStyle="Italic" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
