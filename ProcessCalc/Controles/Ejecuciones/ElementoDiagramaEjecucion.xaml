<UserControl x:Class="ProcessCalc.Controles.ElementoDiagramaEjecucion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300" Width="Auto" Height="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" MouseLeftButtonDown="Clic">
    <Border BorderBrush="Black" BorderThickness="1" MouseLeftButtonDown="Clic">
    <Grid MouseLeftButtonDown="Clic">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
            <Image x:Name="iconoNumero" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/13_01.png"></Image>
            <Image x:Name="iconoNumeros" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/13_02.png"></Image>
            <Image x:Name="iconoSuma" Visibility="Collapsed" Grid.Column="0" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/15_01.png"></Image>
            <Image x:Name="iconoResta" Visibility="Collapsed" Grid.Column="0" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/15_02.png"></Image>
            <Image x:Name="iconoMultiplicacion" Visibility="Collapsed" Grid.Column="0" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/15_04.png"></Image>
            <Image x:Name="iconoDivision" Visibility="Collapsed" Grid.Column="0" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/15_03.png"></Image>
            <Image x:Name="iconoCalculo" Visibility="Collapsed" Grid.Column="0" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/19.png"></Image>
            <Image x:Name="iconoPotencia" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos3/11.png"></Image>
            <Image x:Name="iconoRaiz" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos3/12.png"></Image>
            <Image x:Name="iconoSeleccionarOrdenar" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos4/04.png"></Image>
            <Image x:Name="iconoSeleccionarOrdenar_ConjuntoAgrupado" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos5/agrupados.png"></Image>
            <Image x:Name="iconoCondicionesFlujo" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos4/04.png"></Image>
            <Image x:Name="iconoPorcentaje" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos10/01.png" ></Image>
            <Image x:Name="iconoLogaritmo" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos10/02.png" ></Image>
            <Image x:Name="iconoInverso" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos10/03.png" ></Image>
            <Image x:Name="iconoFactorial" Visibility="Collapsed" Width="24" Height="24" Margin="2" ></Image>
            <Image x:Name="iconoContarCantidades" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos10/09.png"></Image>
            <Image x:Name="iconoTextosInformacion" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos4/12.png"></Image>
            <Image x:Name="iconoSeleccionarEntradas" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos14/icono_02.png"></Image>
            <Image x:Name="iconoEspera" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos14/icono_03.png" ></Image>
            <Image x:Name="iconoLimpiarDatos" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos15/05.png" ></Image>
            <Image x:Name="iconoRedondear" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos16/00_1.png" ></Image>
            <Image x:Name="iconoArchivoExterno" Visibility="Collapsed" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos17/01.png" ></Image>
            <Image x:Name="iconoSubCalculo" Visibility="Collapsed" Width="24" Height="24" Margin="2" Source="/ProcessCalc;component/Imagenes/Iconos18/icono 02.png" ></Image>

            <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="nombreElemento" Margin="2"  Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" MaxWidth="150" HorizontalAlignment="Left">Entrada 1</TextBlock>
            <TextBlock x:Name="tipoElemento" Margin="2"  Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" MaxWidth="150" HorizontalAlignment="Left">Tipo Entrada 1</TextBlock>
        </Grid>
        <ProgressBar x:Name="avanceConjuntoNumeros" Height="10" Grid.Row="1" Grid.ColumnSpan="2" Maximum="100"></ProgressBar>
    </Grid>
    </Border>
</UserControl>
