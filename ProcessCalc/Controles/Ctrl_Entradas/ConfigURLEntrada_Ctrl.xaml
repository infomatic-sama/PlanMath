<UserControl x:Class="ProcessCalc.Controles.Ctrl_Entradas.ConfigURLEntrada_Ctrl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <Button x:Name="configurarEscribirURL" Margin="10" Padding="5" Grid.Column="0" Grid.Row="0" Width="150" Click="configurarEscribirURL_Click">Definir configuración</Button>
        <TextBlock x:Name="etiquetaDefinicionEscribirURL" Margin="10" Grid.Column="1" Grid.Row="0" ></TextBlock>


        <Label x:Name="lblURL" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" VerticalContentAlignment="Center">Dirección de Internet:</Label>
        <TextBox x:Name="txtURL" Grid.Row="1" Grid.Column="1" Margin="10" Grid.ColumnSpan="3" TextChanged="txtURL_TextChanged"></TextBox>

        <Button x:Name="btnMostrarOcultarParametros" Grid.Column="2" Grid.Row="0" Margin="10" Padding="5" Click="btnMostrarOcultarParametros_Click" >Mostrar parámetros</Button>
        <Button x:Name="btnDefinirHeaders" Grid.Column="3" Grid.Row="0" Margin="10" Padding="5" Click="btnDefinirHeaders_Click">Definir headers</Button>

        <ScrollViewer x:Name="tituloParametros" Grid.Column="0" Grid.ColumnSpan="4" Grid.Row="2" Visibility="Collapsed"  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" FontWeight="Bold" Margin="10">Datos a enviar a la URL:</TextBlock>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="enviarParametrosEnUrl" Margin="10" Grid.Column="0" Checked="enviarParametrosEnUrl_Checked" Unchecked="enviarParametrosEnUrl_Unchecked">Enviar los parametros en la url</CheckBox>
                    <CheckBox x:Name="enviarParametrosEnBody" Margin="10" Grid.Column="1" Checked="enviarParametrosEnBody_Checked" Unchecked="enviarParametrosEnBody_Unchecked">Enviar los parametros dentro de la navegación</CheckBox>
                </Grid>

                <TextBlock Grid.Row="2" FontWeight="Bold" Margin="10">Los datos a enviar como parametros se enviaran en formato Json.</TextBlock>

                <Grid x:Name="parametros" Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                </Grid>

            </Grid>
        </ScrollViewer>

        <CheckBox x:Name="opcionEstablecerLecturasNavegaciones_Busquedas" Margin="10" Padding="5" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" VerticalContentAlignment="Center" Checked="opcionEstablecerLecturasNavegaciones_Busquedas_Checked" Unchecked="opcionEstablecerLecturasNavegaciones_Busquedas_Unchecked">Establecer las navegaciones y sus búsquedas a realizar</CheckBox>

        <Button x:Name="btnDefinirTextosInformacionFijos" Grid.Column="0" Grid.Row="3" Margin="10" Padding="5" Width="200" Click="btnDefinirTextosInformacionFijos_Click" >
            <Button.Content>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                    <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                </Grid>
            </Button.Content>
        </Button>

        <local:ConjuntoLecturasNavegacionesEntrada x:Name="conjuntoLecturas" Grid.Row="5" Visibility="Collapsed" Grid.Column="0" Grid.ColumnSpan="3" />
    </Grid>
</UserControl>
