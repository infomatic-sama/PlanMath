<UserControl x:Class="ProcessCalc.Controles.ParametroSolicitudURL_Entrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
  <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock x:Name="espacio" Grid.Column="0" Grid.Row="0" Margin="10"></TextBlock>
        <TextBlock x:Name="nombre" Grid.Column="1" Margin="10" Grid.Row="0">Nombre: </TextBlock>
        <TextBox x:Name="nombreParametro" Grid.Column="2" Margin="10" Grid.Row="0" TextChanged="nombreParametro_TextChanged">Nombre del parámetro</TextBox>

        <TextBlock x:Name="valor" Grid.Column="1" Grid.Row="1" Margin="10">Valor:</TextBlock>
        <TextBox x:Name="valorParametro" Grid.Column="2" Margin="10" Grid.Row="1" TextChanged="valorParametro_TextChanged">Valor del parámetro</TextBox>

        <TextBlock x:Name="elementoDe" Visibility="Collapsed" Grid.Column="2" Grid.Row="3" Grid.RowSpan="2" Margin="10"></TextBlock>

        <CheckBox x:Name="checkEsConjunto" Grid.Column="1" Grid.Row="4" Margin="10" Checked="checkEsConjunto_Checked" Unchecked="checkEsConjunto_Unchecked">Es un conjunto de parámetros</CheckBox>
        <CheckBox x:Name="checkParametroNumerico" Grid.Column="3" Grid.Row="0" Margin="10" Checked="checkParametroNumerico_Checked" Unchecked="checkParametroNumerico_Unchecked" >Parámetro numérico</CheckBox>
        <CheckBox x:Name="checkParametroNumericoConDecimales" Visibility="Collapsed" Grid.Column="3" Grid.Row="1" Margin="10" Checked="checkParametroNumericoConDecimales_Checked" Unchecked="checkParametroNumericoConDecimales_Unchecked" >Con decimales</CheckBox>

        <CheckBox x:Name="enviarParametroEnUrl" Margin="10" Grid.Column="1" Grid.Row="2" Checked="enviarParametroEnUrl_Checked" Unchecked="enviarParametroEnUrl_Unchecked">Enviar parametro en la url</CheckBox>
        <CheckBox x:Name="enviarParametroEnBody" Margin="10" Grid.Column="2" Grid.Row="2" Checked="enviarParametroEnBody_Checked" Unchecked="enviarParametroEnBody_Unchecked">Enviar parametro dentro de la navegación</CheckBox>
    </Grid>
    
</UserControl>
