<UserControl x:Class="ProcessCalc.Controles.EntradaDiseñoOperaciones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"             
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="100" Width="Auto" Height="Auto" AllowDrop="True" VerticalAlignment="Center" SizeChanged="UserControl_SizeChanged">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" TargetType="Button"></Style>
    </UserControl.Resources>
    <Button x:Name="botonFondo" VerticalContentAlignment="Center" BorderBrush="{x:Null}" Width="Auto" Height="Auto" PreviewMouseLeftButtonDown="Button_PreviewMouseLeftButtonDown"  Click="botonFondo_Click" Drop="botonFondo_Drop">
        <StackPanel IsHitTestVisible="True" Orientation="Horizontal" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!--<Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>-->

                <Image x:Name="iconoNumero" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/13_01.png"></Image>
                <Image x:Name="iconoNumeros" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/13_02.png"></Image>
                <Image x:Name="iconoCalculo" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/19.png"></Image>
                <Image x:Name="iconoTextosInformacion" Visibility="Collapsed" Grid.Column="0" Margin="2" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/Iconos4/12.png"></Image>

                <Grid x:Name="grilla" Grid.Column="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="nombreEntrada" VerticalAlignment="Center" Margin="2"  Grid.Row="0" TextWrapping="Wrap" >Entrada 1</TextBlock>
                        <TextBlock x:Name="tipoEntrada" VerticalAlignment="Center" Margin="2"  Grid.Row="1" TextWrapping="Wrap" >Tipo Entrada 1</TextBlock>
                    </Grid>
                </Grid>

                <TextBox x:Name="edicionNombre" TextWrapping="Wrap" Margin="2" Visibility="Collapsed" KeyDown="edicionNombre_KeyDown">Operación 1</TextBox>
                <Button x:Name="btnGuardarNombre" Visibility="Collapsed" Click="btnGuardarNombre_Click">Guardar</Button>

                <TextBox x:Name="edicionNombre_Entrada" TextWrapping="Wrap" Margin="2" Visibility="Collapsed" KeyDown="edicionNombre_Entrada_KeyDown">Operación 1</TextBox>
                <Button x:Name="btnGuardarNombre_Entrada" Visibility="Collapsed" Click="btnGuardarNombre_Entrada_Click">Guardar</Button>
            
            </StackPanel>            
        </StackPanel>
    </Button>
</UserControl>
