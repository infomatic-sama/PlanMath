<UserControl x:Class="ProcessCalc.Controles.Ctrl_Entradas.OpcionListaNumeros_Digitacion_Entrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock x:Name="nombre" Grid.Column="0" Margin="10">Nombre de la variable:</TextBlock>
        <TextBox x:Name="nombreParametro" Grid.Column="1" Margin="10" TextChanged="nombreParametro_TextChanged">Nombre de la variable de número</TextBox>

        <TextBlock x:Name="texto" Grid.Column="2" Margin="10">Variable de número:</TextBlock>
        <TextBox x:Name="textoParametro" Grid.Column="3" Margin="10" TextChanged="textoParametro_TextChanged">1</TextBox>

    </Grid>
</UserControl>
