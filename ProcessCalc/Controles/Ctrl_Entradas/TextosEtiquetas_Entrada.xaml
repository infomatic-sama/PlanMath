<UserControl x:Class="ProcessCalc.Controles.Ctrl_Entradas.TextosEtiquetas_Entrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <TextBlock Margin="10" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center">Agregar cadenas de texto a la variable número:
        </TextBlock>
        <Button x:Name="botonAgregar" Margin="10" Grid.Row="0" Grid.Column="2" Click="Button_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">Agregar nueva cadena de texto</Label>
                    </Grid>
                </Button.Content>
            </Button>

        <Button x:Name="utilizarTextosInformacionDigitacion" Margin="10" Grid.Row="0" Grid.Column="3" Padding="5" Click="utilizarTextosInformacionDigitacion_Click">Utilizar cadenas de texto predefinidas</Button>

        <Grid x:Name="opcionesDigitacion" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Button x:Name="vistaOpcionLista" Margin="10" Grid.Column="0" Grid.Row="0" Click="vistaOpcionLista_Click">
                <Button.Content>
                    <Image Source="/ProcessCalc;component/Imagenes/Iconos3/15.png" Height="24" Width="24" Grid.Column="0"></Image>
                </Button.Content>
            </Button>
            <Button x:Name="vistaOpcionTexto" Margin="10" Grid.Column="1" Grid.Row="0" Click="vistaOpcionTexto_Click">
                <Button.Content>
                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/23.png" Height="24" Width="24" Grid.Column="0"></Image>
                </Button.Content>
            </Button>

        </Grid>

            <Grid x:Name="listaTextos" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
            </Grid>

        </Grid>
        
        <StackPanel x:Name="textoNumeros" Grid.Column="0" Grid.Row="1" Margin="10" Orientation="Vertical" Visibility="Collapsed">
            <TextBlock>El separador entre cadenas de texto es el punto y coma. Se escriben de izquierda a derecha.</TextBlock>
            <TextBox x:Name="listaTextoNumeros" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="listaTextoNumeros_TextChanged"></TextBox>
        </StackPanel>
    </Grid>
</UserControl>
