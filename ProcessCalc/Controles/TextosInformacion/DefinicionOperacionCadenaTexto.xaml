<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.DefinicionOperacionCadenaTexto"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <TextBlock Margin="10" Grid.Row="0" Grid.Column="0">Tipo de operación:</TextBlock>
        <ComboBox x:Name="tipoOperacion" Margin="10" Grid.Row="0" Grid.Column="1" MaxWidth="100" SelectionChanged="tipoOperacion_SelectionChanged">
            <ComboBoxItem Uid="1">Mover</ComboBoxItem>
            <ComboBoxItem Uid="2">Copiar</ComboBoxItem>
            <ComboBoxItem Uid="3">Utilizar</ComboBoxItem>
        </ComboBox>


        <TextBlock x:Name="textoPosicionInicialModoOperacion" Margin="10" Grid.Row="1" Grid.Column="0">Posición inicial:</TextBlock>
        <TextBlock x:Name="textoPosicionInicialModoSeleccion" Visibility="Collapsed" Margin="10" Grid.Row="1" Grid.Column="0">Posición:</TextBlock>
        
        <TextBox x:Name="posicionInicial" Margin="10" Grid.Row="1" Grid.Column="1" MinWidth="100" MaxWidth="100" TextChanged="posicionInicial_TextChanged"></TextBox>

        <TextBlock x:Name="textoPosicionFinal" Margin="10" Grid.Row="2" Grid.Column="0">Posición final:</TextBlock>
        <TextBox x:Name="posicionFinal" Margin="10" Grid.Row="2" Grid.Column="1" MinWidth="100" MaxWidth="100" TextChanged="posicionFinal_TextChanged"></TextBox>

    </Grid>
</UserControl>
