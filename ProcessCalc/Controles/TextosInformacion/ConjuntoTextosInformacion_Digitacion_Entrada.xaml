<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.ConjuntoTextosInformacion_Digitacion_Entrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <TextBlock x:Name="nombre" Grid.Column="0" Margin="10">Nombre:</TextBlock>
        <TextBox x:Name="nombreParametro" Grid.Column="1" Margin="10" TextChanged="nombreParametro_TextChanged">Nombre del vector</TextBox>

        <Button x:Name="textosInformacionPredefinidos" Margin="10" Grid.Column="2" Click="textosInformacionPredefinidos_Click">Cadenas de texto</Button>

        <Grid x:Name="opcionesTextosInformacion_EntradasAnteriores" Visibility="Collapsed" Grid.Column="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Margin="10" Padding="5">Usar las cadenas de texto de la variable o vector de números:</TextBlock>
            <ComboBox x:Name="opcionesEntradasAnteriores" Grid.Column="1" Margin="10" Padding="5" MaxWidth="300" SelectionChanged="opcionesEntradasAnteriores_SelectionChanged"></ComboBox>
            <Button x:Name="quitarSeleccionEntradaAnterior_TextosInformacion" Grid.Column="2" Margin="10" Padding="5" Click="quitarSeleccionEntradaAnterior_TextosInformacion_Click">Quitar selección</Button>
        </Grid>
    </Grid>
</UserControl>
