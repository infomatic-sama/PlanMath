<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.Implicacion_TextosInformacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1300" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="opcionAsignarTextosInformacionAntes_EjecucionOperacion" Margin="10" Grid.Column="0" Grid.Row="0" Checked="opcionAsignarTextosInformacionAntes_EjecucionOperacion_Checked" Unchecked="opcionAsignarTextosInformacionAntes_EjecucionOperacion_Unchecked">Asignar cadenas de texto de estas implicaciones durante la operación (por cada cantidad).</CheckBox>
            <CheckBox x:Name="opcionAsignarTextosInformacionDespues_EjecucionOperacion" Margin="10" Grid.Column="0" Grid.Row="1" Checked="opcionAsignarTextosInformacionDespues_EjecucionOperacion_Checked" Unchecked="opcionAsignarTextosInformacionDespues_EjecucionOperacion_Unchecked">Asignar cadenas de texto de estas implicaciones al obtener resultados (por cada resultado).</CheckBox>

        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Left" Grid.ColumnSpan="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TextBlock Margin="10" Grid.Row="0" Grid.Column="0"  HorizontalAlignment="Left" VerticalAlignment="Center">Agregar lógica de asignación de cadenas de texto:</TextBlock>

            <Button x:Name="agregarTextoInformacion" HorizontalAlignment="Left" Margin="10" MaxWidth="700" Grid.Row="0" Grid.Column="1" Click="agregarTextoInformacion_Click">
                <Button.Content>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Image Source="/ProcessCalc;component/Imagenes/Iconos4/18.png" Height="24" Width="24" Grid.Column="0"></Image>
                        <Label Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">Agregar nueva lógica de asignación</Label>
                    </Grid>
                </Button.Content>
            </Button>
        </Grid>
        

        <Grid x:Name="textosInformacionSeleccionados" Grid.Row="2" Grid.ColumnSpan="8" Margin="10">
            <Grid.ColumnDefinitions>
                
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition ></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
        </Grid>

        <CheckBox x:Name="opcionIncluirAsignacionDentroDefinicionNormal" Visibility="Collapsed" Margin="10" Grid.Column="0" Grid.ColumnSpan="9" Grid.Row="3">Incluir la asignación de estas cadenas de texto durante la lógica dentro de la definición normal</CheckBox>
    </Grid>
</UserControl>
