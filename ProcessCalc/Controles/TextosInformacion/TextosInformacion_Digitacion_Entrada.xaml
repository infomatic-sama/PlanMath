<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.TextosInformacion_Digitacion_Entrada"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>

        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock x:Name="nombre" Grid.Column="0" Margin="10" VerticalAlignment="Center">Nombre de la variable cadena:</TextBlock>
        <TextBox x:Name="nombreParametro" Grid.Column="1" Margin="10" VerticalAlignment="Center" TextChanged="nombreParametro_TextChanged">Nombre de la cadena de texto</TextBox>

        <TextBlock x:Name="texto" Grid.Column="2" Margin="10" VerticalAlignment="Center">Cadena de texto:</TextBlock>
        <TextBox x:Name="textoParametro" Grid.Column="3" Margin="10" VerticalAlignment="Center" TextChanged="textoParametro_TextChanged">Cadena de texto</TextBox>

        <Button x:Name="opcionesPosicion" Grid.Column="4" Margin="10" Padding="5" VerticalAlignment="Center" Click="opcionesPosicion_Click">Posiciones de los números en el vector</Button>
    </Grid>
</UserControl>
