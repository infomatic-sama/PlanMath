<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.OpcionDefiniciones_TextosInformacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Button x:Name="mostrarListaDefiniciones" Grid.Column="0" Grid.Row="0" Margin="10" Click="mostrarListaDefiniciones_Click">Lista de definiciones</Button>
        <TextBlock x:Name="descripcionDefiniciones" Grid.Column="1" Grid.Row="0" Margin="10"></TextBlock>
    </Grid>
    </ScrollViewer>
</UserControl>
