<UserControl x:Class="ProcessCalc.Controles.TextosInformacion.EtiquetaDivision_CadenaTexto_Ordenacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.TextosInformacion"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" MaxHeight="100" Height="100" MaxWidth="300" Width="300">
    <UserControl.Resources>
        <Style BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" TargetType="Button"></Style>
    </UserControl.Resources>
    <Button x:Name="botonBorde" Click="Button_Click">
            <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10" Padding="5">Índice letra inicial:</TextBlock>
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="10" Padding="5">Cantidad de letras:</TextBlock>

            <TextBlock x:Name="letraInicial" Grid.Row="0" Grid.Column="1" Margin="10" Padding="5"></TextBlock>
            <TextBlock x:Name="cantidadLetras" Grid.Row="1" Grid.Column="1" Margin="10" Padding="5"></TextBlock>
        </Grid>
        </Button>
    
</UserControl>
