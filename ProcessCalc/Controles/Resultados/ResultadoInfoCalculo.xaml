<UserControl x:Class="ProcessCalc.Controles.ResultadoInfoCalculo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300" Width="Auto" Height="Auto" AllowDrop="True">
    <Button x:Name="botonFondo" Background="White" BorderBrush="{x:Null}" Width="Auto" Height="Auto" >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image x:Name="icono" Grid.Column="0" Margin="10" Width="24" Height="24" Source="/ProcessCalc;component/Imagenes/14.png"></Image>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="nombreResultado" Margin="2"  Grid.Row="0" TextWrapping="Wrap" MaxWidth="150" >Resultado 1</TextBlock>
                    <TextBlock x:Name="salida" Margin="2"  Grid.Row="1" TextWrapping="Wrap" MaxWidth="150">Salida 1</TextBlock>
                </Grid>

                <TextBlock x:Name="descripcionResultado" Margin="2" VerticalAlignment="Center" Grid.Column="1" TextWrapping="Wrap" MaxWidth="150">Descripción Resultado 1</TextBlock>
            </Grid>

        </Grid>
    </Button>
</UserControl>
