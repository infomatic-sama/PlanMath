<UserControl x:Class="ProcessCalc.Controles.ResultadoEspecifico"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800" Width="Auto" Height="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        
        <Border Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"></Border>

        <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Width="32" Height="32" Margin="10" Source="/ProcessCalc;component/Imagenes/14.png"></Image>

        <Grid Grid.Column="1" Grid.RowSpan="2" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="nombreSalida" Grid.Column="1" Grid.Row="0" Margin="10" TextWrapping="Wrap" MaxWidth="150">Salida 1</TextBlock>
            <TextBlock x:Name="tipoSalida" Grid.Column="1" Grid.Row="1" Margin="10" TextWrapping="Wrap" MaxWidth="150">Tipo Salida 1</TextBlock>
        </Grid>

        <Grid Grid.Column="2" Grid.Row="0" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Margin="10,0,0,0">Descripción:</Label>
            <TextBox x:Name="nombreResultado" Grid.Row="1" Grid.Column="0" Margin="15" TextWrapping="Wrap" TextChanged="nombreResultado_TextChanged"></TextBox>
            <Label Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">Información adicional:</Label>
            <TextBox x:Name="descripcionResultado" Grid.Row="1" Grid.Column="1" Margin="10" TextWrapping="Wrap" TextChanged="descripcionResultado_TextChanged"></TextBox>

        </Grid>

        <Grid Grid.Row="0" Grid.Column="3" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="opcionNoMostrarSiNoTieneNumeros" Grid.Column="0" Grid.Row="0"  Margin="10" VerticalAlignment="Center" Checked="opcionNoMostrarSiNoTieneNumeros_Checked" Unchecked="opcionNoMostrarSiNoTieneNumeros_Unchecked">No mostrar si no tiene cantidades</CheckBox>
            <CheckBox x:Name="opcionNoMostrarSiEsCero" Grid.Column="0" Grid.Row="1" Margin="10" VerticalAlignment="Center" Checked="opcionNoMostrarSiEsCero_Checked" Unchecked="opcionNoMostrarSiEsCero_Unchecked">No mostrar si es cero</CheckBox>
        </Grid>
        
    </Grid>
</UserControl>
