<UserControl x:Class="ProcessCalc.Controles.AperturaArchivoEspecifica"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Image x:Name="icono" Grid.Column="0" Width="24" Height="24" Margin="10" Source="/ProcessCalc;component/Imagenes/09.png" ></Image>

        <TextBlock x:Name="nombreArchivo" Margin="5"  Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Center" Cursor="Hand" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" MouseLeftButtonUp="nombreArchivo_MouseLeftButtonUp">Nombre Archivo 1</TextBlock>
        <TextBlock x:Name="descripcionCalculo" Margin="5"  Grid.Column="2" TextWrapping="Wrap" VerticalAlignment="Center">Descripcion calculo 1</TextBlock>
        <TextBlock x:Name="fechaHoraApertura" Margin="5"  Grid.Column="3" TextWrapping="Wrap" VerticalAlignment="Center">Fecha y hora de apertura calculo 1</TextBlock>

        <TextBlock x:Name="rutaArchivo" Margin="5" VerticalAlignment="Center" Grid.Column="4" TextWrapping="Wrap" >Ruta Archivo 1</TextBlock>
        <Button x:Name="btnAbrirCarpeta" Grid.Column="5" Margin="5" VerticalAlignment="Center" Click="btnAbrirCarpeta_Click">Abrir carpeta</Button>
        <Button x:Name="btnQuitar" Grid.Column="6" Margin="5" VerticalAlignment="Center" Click="btnQuitar_Click">Quitar</Button>

    </Grid>
</UserControl>
