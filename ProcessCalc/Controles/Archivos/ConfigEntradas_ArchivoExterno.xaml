<UserControl x:Class="ProcessCalc.Controles.Archivos.ConfigEntradas_ArchivoExterno"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc.Controles.Archivos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded" >
    <Border BorderBrush="White" BorderThickness="0,0,0,0.5">
        <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock x:Name="nombreEntradaOperacion" Margin="10" Grid.Column="0" Grid.Row="0">Entrada y operación</TextBlock>

        <CheckBox x:Name="opcionUsarEstaConfiguracion" Margin="10" Grid.Row="0" Grid.Column="1" Checked="opcionUsarEstaConfiguracion_Checked" Unchecked="opcionUsarEstaConfiguracion_Unchecked">
            <TextBlock>Usar esta configuración en lugar de la configuración
            <TextBlock x:Name="textoConfiguracionOpuesta"></TextBlock>
            </TextBlock>
        </CheckBox>

        <RadioButton x:Name="opcionUsarElementoConectado" Margin="10"  Grid.Row="1" Grid.Column="0" GroupName="OpcionesEntrada" Checked="opcionUsarElementoConectado_Checked">Usar las cantidades de la variable o vector u operación conectada a la entrada</RadioButton>
        <RadioButton x:Name="opcionUsarEntradaOriginal" Margin="10"  Grid.Row="2" Grid.Column="0" GroupName="OpcionesEntrada" Checked="opcionUsarEntradaOriginal_Checked">Usar las cantidades originales de la variable o vector de la entrada</RadioButton>
        <RadioButton x:Name="opcionUsarElementoConectadoEntradaOriginal" Margin="10"  Grid.Row="3" Grid.Column="0" GroupName="OpcionesEntrada" Checked="opcionUsarElementoConectadoEntradaOriginal_Checked">Usar las cantidades originales de la variable o vector de la entrada y las cantidades de la variable o vector u operación conectada</RadioButton>
    </Grid>
    </Border>
</UserControl>
