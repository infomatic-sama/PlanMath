<UserControl x:Class="ProcessCalc.Controles.BusquedaEnArchivo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="850" Height="Auto" MaxWidth="850" Width="Auto"  Margin="20" BorderThickness="1" BorderBrush="Black" Loaded="UserControl_Loaded" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}"
             HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Grid x:Name="contenedorGrilla">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Button x:Name="botonFondo" Background="{x:Null}" Width="Auto" Height="Auto" Click="Button_Click" BorderBrush="{x:Null}" ClickMode="Press">
            <Grid x:Name="grilla" Grid.Row="0">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                <Image x:Name="icono" Grid.Row="0" Grid.Column="0" Width="32" Height="32" Margin="5" Source="/ProcessCalc;component/Imagenes/18.png"></Image>

                    <Button x:Name="condicionesBusqueda" Margin="10" Grid.Row="1" Click="condicionesBusqueda_Click">
                        <TextBlock>Condiciones a cumplir
                        <LineBreak></LineBreak>para ejecutar esta búsqueda
                        </TextBlock></Button>
                                    
                    <Grid Grid.Row="2" Grid.ColumnSpan="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        
                        <RadioButton x:Name="opcionGeneracionFilas" GroupName="OpcionesFilasTextosInformacion" Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Margin="5" Checked="opcionGeneracionFilas_Checked" Unchecked="opcionGeneracionFilas_Unchecked">
                            <TextBlock>Con cada cadena de texto encontrado generar <LineBreak></LineBreak>agrupación o fila (vector de cadenas de texto)</TextBlock>
                        </RadioButton>

                        <RadioButton x:Name="opcionGeneracionFilasBusqueda" GroupName="OpcionesFilasTextosInformacion" IsChecked="True" Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Margin="5">
                            <TextBlock>Generar agrupación o fila (vector de cadenas de texto) con<LineBreak></LineBreak>las cadenas de texto de esta búsqueda</TextBlock>
                        </RadioButton>

                        <CheckBox x:Name="chkIncluirTextosInformacion_BusquedaContenedora" Visibility="Collapsed" Margin="5" Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Checked="chkIncluirTextosInformacion_BusquedaContenedora_Checked" Unchecked="chkIncluirTextosInformacion_BusquedaContenedora_Unchecked" >
                            <TextBlock>
    Incluir textos de información <LineBreak></LineBreak>
    de búsqueda contenedora
                            </TextBlock>
                        </CheckBox>

                        <CheckBox x:Name="chkEsConjuntoBusquedas" Margin="5" Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" Checked="chkEsConjuntoBusquedas_Checked" Unchecked="chkEsConjuntoBusquedas_Unchecked">
                            <TextBlock>
Es un conjunto <LineBreak></LineBreak>
de búsquedas
                            </TextBlock>
                        </CheckBox>

                        <RadioButton x:Name="opcionGeneracionFilas_BusquedasConjuntos" GroupName="OpcionesFilasTextosInformacion" Grid.Column="1" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" Margin="5" Checked="opcionGeneracionFilas_BusquedasConjuntos_Checked" Unchecked="opcionGeneracionFilas_BusquedasConjuntos_Unchecked">
                            <TextBlock>Con cada búsqueda del conjunto y sus cadenas de texto<LineBreak></LineBreak>encontradas generar agrupación o fila (vector de cadenas de texto)</TextBlock>
                        </RadioButton>

                        <RadioButton x:Name="opcionGeneracionFilas_IteracionBusquedasConjuntos" GroupName="OpcionesFilasTextosInformacion" Grid.Column="2" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" Margin="5" Checked="opcionGeneracionFilas_IteracionBusquedasConjuntos_Checked" Unchecked="opcionGeneracionFilas_IteracionBusquedasConjuntos_Unchecked">
                            <TextBlock>Con cada iteración del conjunto de búsquedas y sus cadenas de texto<LineBreak></LineBreak>encontradas generar agrupación o fila (vector de cadenas de texto)</TextBlock>
                        </RadioButton>

                        <RadioButton x:Name="opcionNoGeneracionFilas" GroupName="OpcionesFilasTextosInformacion" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" VerticalAlignment="Center" Margin="5" Checked="opcionNoGeneracionFilas_Checked" Unchecked="opcionNoGeneracionFilas_Unchecked" >
                            <TextBlock>No generar filas o agrupaciones (vector de cadenas de texto) con las cadenas de texto encontradas en esta búsqueda</TextBlock>
                        </RadioButton>
                    </Grid>

                    

                    <Grid Grid.Column="3" Grid.RowSpan="2" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Label Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Margin="10">Nombre:</Label>
                    <TextBox x:Name="nombreBusqueda" Margin="10" TextWrapping="Wrap" Text="Búsqueda 1" FontSize="14" Grid.Row="0" Grid.Column="1" AcceptsReturn="True" TextChanged="nombreBusqueda_TextChanged" VerticalAlignment="Center"></TextBox>
                    <Label Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Margin="10">Descripción:</Label>
                    <TextBox x:Name="descripcionBusqueda" Margin="10" TextWrapping="Wrap" Text="Descripción Búsqueda 1" Grid.Row="1" Grid.Column="1"  AcceptsReturn="True" TextChanged="descripcionBusqueda_TextChanged" VerticalAlignment="Center"/>

                </Grid>

                <Grid x:Name="opcionesOtraBusqueda" Grid.Column="4" Grid.RowSpan="2" >
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label x:Name="lblOtraBusqueda" Margin="10" Visibility="Collapsed">¿Quieres agregar otra búsqueda?</Label>
                    <Button x:Name="btnOtraBusqueda" Margin="10" Grid.Row="1" Padding="20,1" Visibility="Collapsed" Click="btnBusquedaInterna_Click" >Agregar búsqueda a esta búsqueda</Button>
                        <Label x:Name="lblQuitarBusqueda" Margin="10" Grid.Row="3">¿Quieres quitar esta búsqueda?</Label>
                    <Button x:Name="btnQuitarBusqueda" Margin="10" Grid.Row="4" Padding="20,1" Click="btnQuitarBusquedaInterna_Click" >Quitar esta búsqueda</Button>
                </Grid>

                <Button x:Name="subir" Grid.Column="5" Grid.Row="0" Margin="10" Click="subir_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/35.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
                <Button x:Name="bajar" Grid.Column="5" Grid.Row="1" Margin="10" Click="bajar_Click">
                    <Button.Content>
                        <Image Source="/ProcessCalc;component/Imagenes/34.png" Width="16" Height="16"></Image>
                    </Button.Content>
                </Button>
            </Grid>

                
        </Button>

        <Grid x:Name="busquedasConjunto" Grid.Row="2" Margin="10" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <CheckBox x:Name="opcionEjecutarBusquedaCabeceraIteraciones" Grid.Row="0" Margin="10" Checked="opcionEjecutarBusquedaCabeceraIteraciones_Checked" Unchecked="opcionEjecutarBusquedaCabeceraIteraciones_Unchecked">Ejecutar la búsqueda de cabecera del conjunto en cada iteración</CheckBox>
            <TextBlock Grid.Row="1" Margin="10">El conjunto de búsquedas se repetirá según las condiciones (si/entonces):</TextBlock>
            <Grid x:Name="contenedorCondicionesConjunto" Grid.Row="2">
                <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <RadioButton x:Name="opcionHastaFinalArchivo" Margin="10" Grid.Column="0" Grid.Row="0" VerticalContentAlignment="Center" Checked="opcionHastaFinalArchivo_Checked" GroupName="Repetir">Bucle de búsquedas hasta el final del archivo</RadioButton>
                <RadioButton x:Name="opcionMientrasCondicionesCumplan" Margin="10" Grid.Column="0" Grid.Row="1" VerticalContentAlignment="Center" Checked="opcionMientrasCondicionesCumplan_Checked" GroupName="Repetir" Unchecked="opcionMientrasCondicionesCumplan_Unchecked">Bucle de búsquedas mientras las condiciones (si/entonces) se cumplan</RadioButton>
                    <RadioButton x:Name="opcionHastaCondicionesCumplan" Margin="10" Grid.Column="0" Grid.Row="2" VerticalContentAlignment="Center" Checked="opcionHastaCondicionesCumplan_Checked" GroupName="Repetir" Unchecked="opcionHastaCondicionesCumplan_Unchecked">Bucle de búsquedas hasta que las condiciones (si/entonces) se cumplan</RadioButton>

                <Grid x:Name="contenedorCondicionesNVeces" Grid.Column="0" Grid.Row="3" Margin="10">
                    <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>

                    <RadioButton x:Name="opcionNveces" Grid.Column="0" Grid.Row="0" VerticalContentAlignment="Center" Checked="opcionNveces_Checked" GroupName="Repetir">Bucle de búsquedas de:</RadioButton>
                        <TextBox x:Name="txtVeces" Grid.Row="0" Grid.Column="1" Width="70" Margin="20" IsReadOnly="False" TextAlignment="Center" VerticalContentAlignment="Center" TextChanged="txtVeces_TextChanged"/>
                        <Label x:Name="lblVeces2" Grid.Row="0" Grid.Column="2" VerticalContentAlignment="Center">veces</Label>

                </Grid>

                <Grid x:Name="estructuraCondiciones" Grid.Column="0" Grid.Row="4" Margin="10" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Condiciones (si/entonces):</TextBlock>
                    <Grid Grid.Row="1" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                                <RowDefinition Height="Auto"></RowDefinition>
                            </Grid.RowDefinitions>

                        <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar</Button>
                        <Button x:Name="editarCondicion" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicion_Click">Editar</Button>
                        <Button x:Name="quitarCondicion" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicion_Click" >Quitar</Button>
                        <Button x:Name="moverCondicionAIzquierda" Grid.Row="1" Grid.Column="0" Margin="10" Click="moverCondicionAIzquierda_Click" >Mover a izquierda</Button>
                        <Button x:Name="moverCondicionADerecha" Grid.Row="1" Grid.Column="1" Margin="10" Click="moverCondicionADerecha_Click">Mover a derecha</Button>

                    </Grid>
                    
                    
                        <WrapPanel x:Name="listaCondiciones"  Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto"></WrapPanel>
                    
                </Grid>

            </Grid>

                <Grid x:Name="opcionesTextosInformacionNombresCantidades" Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Cadenas de texto y nombres de números por iteración del bucle:</TextBlock>
                    <CheckBox x:Name="opcionEstablecerNombresCantidadesIteracion" Margin="10" HorizontalAlignment="Left" Grid.Row="1" Grid.Column="0" Checked="opcionEstablecerNombresCantidadesIteracion_Checked" Unchecked="opcionEstablecerNombresCantidadesIteracion_Unchecked">Establecer nombres de números de la iteración</CheckBox>
                    <CheckBox x:Name="opcionEstablecerNombresCantidadesBusquedasIteracion" Margin="10" HorizontalAlignment="Left" Grid.Row="2" Grid.Column="0" Checked="opcionEstablecerNombresCantidadesBusquedasIteracion_Checked" Unchecked="opcionEstablecerNombresCantidadesBusquedasIteracion_Unchecked">Establecer nombres de números de cada búsqueda de la iteración del bucle</CheckBox>

                    <Button x:Name="btnDefinirTextosInformacionIteracion" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="3" Margin="50,2,2,2" Padding="2" Width="200" Click="btnDefinirTextosInformacionIteracion_Click" >
                        <Button.Content>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                            </Grid>
                        </Button.Content>
                    </Button>

                    <Button x:Name="opcionesNombresCantidadesIteracion" HorizontalAlignment="Left" Margin="10" Padding="5" Width="200" Grid.Column="0" Grid.Row="4" Click="opcionesNombresCantidadesIteracion_Click">
                        <TextBlock>Opciones de nombres de números</TextBlock>
                    </Button>
                </Grid>

            <TextBlock Grid.Row="4" Margin="10">Búsquedas a realizar dentro del bucle:</TextBlock>
            <StackPanel x:Name="contenedorBusquedasConjunto" Grid.Row="5" Margin="10"></StackPanel>
        </Grid>
    </Grid>
    </ScrollViewer>
</UserControl>
