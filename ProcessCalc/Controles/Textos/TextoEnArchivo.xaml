<UserControl xmlns:Busquedas="clr-namespace:ProcessCalc.Controles.Busquedas"  xmlns:TextosInformacion="clr-namespace:ProcessCalc.Controles.TextosInformacion"  x:Class="ProcessCalc.Controles.TextoEnArchivo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProcessCalc"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1000" AllowDrop="True" Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" x:Name="nombreBusqueda" FontWeight="Bold" Margin="10">Nombre búsqueda seleccionada</TextBlock>

            <TextBlock x:Name="textoEtiqueta" Margin="10" FontSize="14" Grid.Row="1">Buscar la siguiente cadena de texto para encontrar números.<LineBreak></LineBreak>Los iconos son subcadenas de la cadena de texto que cambian según la búsqueda en su ubicación especifica.</TextBlock>
            <TextBlock x:Name="textoEtiquetaTextosInformacion" Visibility="Collapsed" Margin="10" FontSize="14" Grid.Row="1">Buscar esta cadena de texto para encontrar otras cadenas de texto. Arrastra el icono para agregarlos a la cadena de texto total. Utiliza espacios entre las palabras y los iconos que agregues, para facilitar el manejo de la cadena de texto:</TextBlock>

            <Grid Grid.Row="2" Width="Auto" HorizontalAlignment="Left" AllowDrop="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Label x:Name="textoIconoNumero" Grid.Column="0" VerticalContentAlignment="Center" Margin="10">Número:</Label>
                <Image x:Name="numero" Grid.Column="1" Width="24" Height="24" Margin="10"  AllowDrop="True" MouseMove="numero_Arrastre" Source="/ProcessCalc;component/Imagenes/13_01.png" MouseLeftButtonUp="numero_MouseLeftButtonUp" />

                <Label x:Name="textoIconoDatos" Grid.Column="2" VerticalContentAlignment="Center" Margin="10">Cadena de texto cambiante:</Label>
                <Image x:Name="datos" Grid.Column="3" Width="24" Height="24" Margin="10"  MouseMove="datos_Arrastre" Source="/ProcessCalc;component/Imagenes/22.png" MouseLeftButtonUp="datos_MouseLeftButtonUp" />

                <Label Grid.Column="4" VerticalContentAlignment="Center" Margin="10">Cadenas de texto:</Label>
                <Image x:Name="textos" Grid.Column="5" Width="24" Height="24" Margin="10"  MouseMove="textos_Arrastre" Source="/ProcessCalc;component/Imagenes/Iconos4/03.png" MouseLeftButtonUp="textos_MouseLeftButtonUp" />

            </Grid>
        </Grid>

        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid >
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0">
                <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Margin="10">Cadena de texto de búsqueda:</TextBlock>

                <TextBox x:Name="textoArchivo" Grid.Row="1" Grid.Column="0" Margin="10" TextWrapping="Wrap" AllowDrop="True" KeyUp="textoArchivo_KeyUp" AcceptsReturn="True" Drop="textoArchivo_Drop" FontSize="16" DragOver="textoArchivo_DragOver" PreviewDragOver="textoArchivo_PreviewDragOver" TextChanged="textoArchivo_TextChanged" SelectionChanged="textoArchivo_SelectionChanged" SizeChanged="textoArchivo_SizeChanged" KeyDown="textoArchivo_KeyDown" PreviewKeyDown="textoArchivo_KeyDown" MouseLeftButtonDown="textoArchivo_MouseLeftButtonDown" />

                <Canvas x:Name="contenidoImagen" Grid.Row="1" Grid.Column="0" Margin="10" />
            </Grid>
            <TextBlock x:Name="errorIconosJuntos" Margin="10" Grid.Row="1" Visibility="Collapsed">La búsqueda no debe contener campos de datos, textos de información o el número juntos sin al menos 1 caracter entre ellos.</TextBlock>

            <Grid Grid.Column="0" Grid.Row="2" x:Name="contenido" Margin="10" AllowDrop="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                        <RowDefinition Height="Auto" AllowDrop="True"/>
                        <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                    <RowDefinition Height="Auto" AllowDrop="True"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition AllowDrop="True"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    
                    <TextBlock x:Name="textoNormal" FontSize="14" Grid.Row="0" VerticalAlignment="Center" TextWrapping="Wrap" Margin="10" >Indicaciones para la búsqueda:

    <LineBreak/><LineBreak/>Escribe la cadena de texto total que la aplicación buscará, que contiene los números.<LineBreak/>Arrastra los iconos hasta la posición deseada en la cadena de texto total.
<LineBreak/>Utiliza espacios entre las palabras y los iconos que agregues, para facilitar el manejo de la cadena de texto total.

                    </TextBlock>
                    <TextBlock x:Name="textoTextosInformacion" Visibility="Collapsed" FontSize="14" Grid.Row="1" VerticalAlignment="Center" TextWrapping="Wrap" Margin="10" >Indicaciones para definir la búsqueda:

    <LineBreak/><LineBreak/>Escribe la cadena de texto total que la aplicación buscará, que contiene las otras cadenas de texto.<LineBreak/>Arrastra los iconos que representan las cadenas de texto hasta la posiciones en la cadena de texto total, que la aplicación identificará como ubicación de las cadenas de texto.
<LineBreak/><LineBreak/>Las cadenas de texto se utilizarán para filtrar y ordenar a los números en los cálculos.
                    </TextBlock>

                </Grid>

                <Grid x:Name="opcionesCondicionesBusquedaRepeticiones" Grid.Row="1" HorizontalAlignment="Left" Width="Auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="10" Grid.Row="0" Grid.Column="0">Condiciones del bucle de búsqueda:</TextBlock>
                    
                    <RadioButton x:Name="opcionHastaFinalArchivo" Margin="10" Grid.Column="1" Grid.Row="1" VerticalContentAlignment="Center" Checked="opcionHastaFinalArchivo_Checked" GroupName="Encontrar">Encontrar coincidencias de la cadena de texto total hasta el final del archivo</RadioButton>
                        <RadioButton x:Name="opcionMientrasCondicionesCumplan" Margin="10" Grid.Column="0" Grid.Row="2" VerticalContentAlignment="Center" Checked="opcionMientrasCondicionesCumplan_Checked" GroupName="Encontrar" Unchecked="opcionMientrasCondicionesCumplan_Unchecked">Encontrar coincidencias de la cadena de texto total mientras las condiciones (si/entonces) se cumplan</RadioButton>
                        <RadioButton x:Name="opcionHastaCondicionesCumplan" Margin="10" Grid.Column="1" Grid.Row="2" VerticalContentAlignment="Center" GroupName="Encontrar" Checked="opcionHastaCondicionesCumplan_Checked" Unchecked="opcionHastaCondicionesCumplan_Unchecked">Encontrar coincidencias de la cadena de texto total hasta que las condiciones (si/entonces) se cumplan</RadioButton>
                    
                        <Grid Grid.Column="0" Grid.Row="1" Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="opcionNveces" Grid.Column="0" VerticalContentAlignment="Center" Checked="opcionNveces_Checked" GroupName="Encontrar">Encontrar en el bucle:</RadioButton>
                        <TextBox x:Name="txtVeces" Grid.Column="1" Width="70" Margin="20" IsReadOnly="False" TextAlignment="Center" VerticalContentAlignment="Center" TextChanged="txtVeces_TextChanged"/>
                            <Label x:Name="lblVeces2" Grid.Column="2" VerticalContentAlignment="Center">coincidencias de la cadena de texto total</Label>

                    </Grid>

                        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="textoCondicionesBusqueda" Visibility="Collapsed" Grid.Row="0" Grid.Column="0" Margin="10">Condiciones del bucle de búsqueda: </TextBlock>

                            <Grid x:Name="opcionesCondicionesBusqueda" Visibility="Collapsed" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"></RowDefinition>
                                </Grid.RowDefinitions>

                                <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar</Button>
                                <Button x:Name="editarCondicion" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicion_Click">Editar</Button>
                                <Button x:Name="quitarCondicion" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicion_Click" >Quitar</Button>
                                <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierda_Click" >Mover a izquierda</Button>
                                <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerecha_Click">Mover a derecha</Button>

                            </Grid>


                            <WrapPanel x:Name="listaCondiciones"  Visibility="Collapsed"  Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"  Orientation="Horizontal" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto"></WrapPanel>

                        </Grid>
                </Grid>

                    <Grid x:Name="opcionesCondicionesFiltrosBusqueda" Grid.Row="2" HorizontalAlignment="Left" Width="Auto">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="10" Grid.Row="0" Grid.Column="0">Condiciones (si/entonces) de selección de cadenas de texto en el bucle:</TextBlock>
                              
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>

                            <Grid x:Name="opcionesCondicionesBusquedaFiltros" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"></RowDefinition>
                                </Grid.RowDefinitions>

                                <Button x:Name="agregarCondicionFiltros" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicionFiltros_Click" >Agregar</Button>
                                <Button x:Name="editarCondicionFiltros" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicionFiltros_Click">Editar</Button>
                                <Button x:Name="quitarCondicionFiltros" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicionFiltros_Click" >Quitar</Button>
                                <Button x:Name="moverCondicionAIzquierdaFiltros" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierdaFiltros_Click" >Mover a izquierda</Button>
                                <Button x:Name="moverCondicionADerechaFiltros" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerechaFiltros_Click">Mover a derecha</Button>

                            </Grid>


                            <WrapPanel x:Name="listaCondicionesFiltros"  Grid.Row="1" Grid.Column="0"  Orientation="Horizontal" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto"></WrapPanel>

                        </Grid>
                    </Grid>

                    <Grid x:Name="opcionesCodificacion" Grid.Row="3" HorizontalAlignment="Left" Width="Auto">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Margin="10" VerticalContentAlignment="Center" Grid.Column="0">Codificación de texto del archivo:</Label>
                    <ComboBox x:Name="opcionCodificacion" Margin="10" VerticalAlignment="Center" Grid.Column="1" MinWidth="500" SelectionChanged="opcionCodificacion_SelectionChanged"></ComboBox>

                </Grid>

                <Grid x:Name="opcionesTextosInformacion" Grid.Row="4" HorizontalAlignment="Left" Width="Auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="10" VerticalAlignment="Center">Asignar las cadenas de texto a:</TextBlock>
                    <RadioButton x:Name="opcionNumeroActual" Grid.Row="0" Grid.Column="1" Margin="10" IsChecked="True" VerticalAlignment="Center" Checked="opcionNumeroActual_Checked">Número actual dentro del bucle</RadioButton>
                    <RadioButton x:Name="opcionUltimoNumeroEncontrado" Grid.Row="0" Grid.Column="2" Margin="10" VerticalAlignment="Center" Checked="opcionUltimoNumeroEncontrado_Checked">Últimos números encontrados en el bucle</RadioButton>
                    <RadioButton x:Name="opcionSiguienteNumeroAEncontrar" Grid.Row="0" Grid.Column="3" Margin="10" VerticalAlignment="Center" Checked="opcionSiguienteNumeroAEncontrar_Checked" Unchecked="opcionSiguienteNumeroAEncontrar_Unchecked">Siguientes números a encontrar dentro del bucle</RadioButton>

                    <ComboBox x:Name="opcionAsignarTextosInformacionNumeros" Grid.Row="0" Grid.Column="4" Margin="10" VerticalAlignment="Center" SelectionChanged="opcionAsignarTextosInformacionNumeros_SelectionChanged">
                        <ComboBoxItem Content="Todos los números" Uid="1"/>
                        <ComboBoxItem Uid="2">
                            <ComboBoxItem.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Label Margin="10" VerticalAlignment="Center">Cantidad de números:</Label>
                                    <TextBox x:Name="cantidadNumerosAsignarTextosInformacion" VerticalAlignment="Center" Margin="10" Padding="10" TextChanged="cantidadNumerosAsignarTextosInformacion_TextChanged">1</TextBox>
                                </StackPanel>
                            </ComboBoxItem.Content>
                        </ComboBoxItem>
                        <ComboBoxItem Content="Números buscados que contengan textos de información" Uid="3"></ComboBoxItem>
                        <ComboBoxItem Content="Números encontrados por búsquedas de esta entrada" Uid="4"></ComboBoxItem>
                    </ComboBox>

                    <TextosInformacion:SeleccionOrdenamiento_TextosInformacion x:Name="textosInformacion_SeleccionNumeros" Grid.ColumnSpan="5" Grid.Row="1" Visibility="Collapsed" />
                    <Busquedas:SeleccionarBusquedasNumeros x:Name="busquedas_SeleccionNumeros" Grid.ColumnSpan="5" Grid.Row="1" Visibility="Collapsed" />

                        <ComboBox x:Name="opcionAsignarTextosInformacionNumeros_Iteraciones" Grid.Row="0" Grid.Column="5" Margin="10" VerticalAlignment="Center" SelectionChanged="opcionAsignarTextosInformacionNumeros_Iteraciones_SelectionChanged">
                            <ComboBoxItem Content="Todas las iteraciones" Uid="1"/>
                            <ComboBoxItem Uid="2">
                                <ComboBoxItem.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Label Margin="10" VerticalAlignment="Center">Cantidad de iteraciones del bucle:</Label>
                                        <TextBox x:Name="cantidadNumerosAsignarTextosInformacion_Iteraciones" VerticalAlignment="Center" Margin="10" Padding="10" TextChanged="cantidadNumerosAsignarTextosInformacion_Iteraciones_TextChanged">1</TextBox>
                                    </StackPanel>
                                </ComboBoxItem.Content>
                            </ComboBoxItem>
                            <ComboBoxItem x:Name="opcionIteracionActual" Content="Iteración actual" Uid="3"></ComboBoxItem>
                        </ComboBox>

                    </Grid>

                <Grid x:Name="opcionesModoNormal" Margin="10" Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>
                            
                            <CheckBox x:Name="opcionUsarCeros" Grid.Column="0" VerticalAlignment="Center" Checked="opcionUsarCeros_Checked" Unchecked="opcionUsarCeros_Unchecked">
                                <TextBlock>Si no se encuentran números en el bucle
                                <LineBreak></LineBreak> usar la siguiente cantidad:</TextBlock>
                            </CheckBox>

                            <TextBox x:Name="txtCantidadUtilizar_NoEncontrados" Grid.Column="1" Width="70" Margin="20" IsReadOnly="False" TextAlignment="Center" VerticalContentAlignment="Center" TextChanged="txtCantidadUtilizar_NoEncontrados_TextChanged"/>
                        </Grid>
                    
                    <Button x:Name="btnDefinirTextosInformacionFijos" Grid.Column="1" Margin="50,2,2,2" Padding="2" Width="200" Click="btnDefinirTextosInformacionFijos_Click" >
                        <Button.Content>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Image Source="/ProcessCalc;component/Imagenes/Iconos4/01.png" Height="24" Width="24" Grid.Column="0"></Image>
                                <Label Grid.Column="1" VerticalAlignment="Center">Cadenas de texto fijas</Label>
                            </Grid>
                        </Button.Content>
                    </Button>

                    <Button x:Name="opcionesNombresCantidades" Margin="10" Padding="5" Grid.Column="2" Click="opcionesNombresCantidades_Click">
                        <TextBlock>Opciones de nombres de números</TextBlock>
                    </Button>
                </Grid>

                    <Grid x:Name="opcionesModoTextosInformacion" Margin="10" Grid.Row="5" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="opcionesNombresCantidades_TextosInformacion"  Margin="10" Padding="5" Width="250" Grid.Row="0" Grid.Column="0" Click="opcionesNombresCantidades_Click">
                            <TextBlock>Opciones de nombres de filas (vector de cadenas de texto)</TextBlock>
                        </Button>

                        <RadioButton x:Name="opcionAgregarTextosInformacion_NombresCantidades" Grid.Row="0" Grid.Column="1" Margin="10" GroupName="OpcionesTextosInformacion_NombresCantidades">Agregar a las cadenas de texto encontradas</RadioButton>
                        <RadioButton x:Name="opcionReemplazarTextosInformacion_NombresCantidades" Grid.Row="0" Grid.Column="2" Margin="10" GroupName="OpcionesTextosInformacion_NombresCantidades" Checked="opcionReemplazarTextosInformacion_NombresCantidades_Checked" Unchecked="opcionReemplazarTextosInformacion_NombresCantidades_Unchecked">Reemplazar las cadenas de texto encontradas</RadioButton>
                    </Grid>
                    
                </Grid>
        </Grid>
        
        </ScrollViewer>
    </Grid>
    
</UserControl>
