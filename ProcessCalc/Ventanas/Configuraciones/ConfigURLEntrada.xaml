<Window x:Class="ProcessCalc.Ventanas.ConfigURLEntrada"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Configuración de URL" Height="230" Width="800" WindowStyle="ToolWindow" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <RadioButton x:Name="opcionURLFija" Grid.Row="0" Grid.Column="0" Margin="10" VerticalAlignment="Center" Checked="opcionURLFija_Checked">Utilizar la URL indicada</RadioButton>
            <RadioButton x:Name="opcionEscribirURL" Grid.Row="0" Grid.Column="1" Margin="10" VerticalAlignment="Center" Checked="opcionEscribirURL_Checked">Escribir URL en la ejecución</RadioButton>
            <RadioButton x:Name="opcionEscribirURLPorEntrada" Grid.Row="1" Grid.ColumnSpan="3" VerticalContentAlignment="Center" Margin="10" Checked="opcionEscribirURLPorEntrada_Checked">Elegir escribir URL en la ejecución, por cada variable o vector de entrada</RadioButton>
            <CheckBox x:Name="establecerParametrosEnEjecucion" Margin="10" Grid.Row="2" Grid.ColumnSpan="3" Checked="establecerParametrosEnEjecucion_Checked" Unchecked="establecerParametrosEnEjecucion_Unchecked">Establecer parámetros de la URL en la ejecución</CheckBox>
        </Grid>
        <Button x:Name="cerrar" Grid.Row="1" Margin="10" Width="100" HorizontalAlignment="Right" Click="cerrar_Click">Cerrar</Button>
    </Grid>
</Window>
