<Window x:Class="ProcessCalc.Ventanas.ConfigSeleccionPosicionesTextos_Entrada"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Configuración de selección de posiciones de cadenas de texto en vector" Height="450" Width="800" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Margin="10">Definición de lógica de selección de números:</TextBlock>
        <RadioButton x:Name="opcionTodosNumeros" Grid.Row="1" Grid.Column="0" Margin="10" GroupName="Opciones" VerticalAlignment="Center" Checked="opcionTodosNumeros_Checked">Seleccionar todos las cadenas de texto obtenidas de la variable o vector</RadioButton>
        <RadioButton x:Name="opcionPosicionesNumerosDeterminadas" Grid.Row="2" Grid.Column="0" Margin="10"  GroupName="Opciones" VerticalAlignment="Center" Checked="opcionCantidadNumerosDeterminada_Checked">Seleccionar las siguientes posiciones de cadenas de texto obtenidas de la variable o vector (separadas por coma):</RadioButton>
        <TextBox x:Name="posicionesNumeros" Grid.Row="2" Grid.Column="1" Margin="50,0,100,0" VerticalAlignment="Center" MinWidth="100" TextChanged="cantidadNumeros_TextChanged"></TextBox>
        <CheckBox x:Name="opcionNumerosCondicion" Grid.Row="3" Grid.Column="0" Margin="10" VerticalAlignment="Center" Checked="opcionNumerosCondicion_Checked" Unchecked="opcionNumerosCondicion_Unchecked">Seleccionar las cadenas de texto cuya posición en el vector cumple las condiciones si/entonces:</CheckBox>

        <Grid x:Name="estructuraCondiciones" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" Margin="10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition ></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition ></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Condiciones si/entonces:</TextBlock>

            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar</Button>
                <Button x:Name="editarCondicion" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicion_Click">Editar</Button>
                <Button x:Name="quitarCondicion" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicion_Click" >Quitar</Button>
                <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierda_Click" >Mover a izquierda</Button>
                <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerecha_Click">Mover a derecha</Button>

            </Grid>

            <ScrollViewer x:Name="contenedorListaCondiciones" Grid.Row="2" Grid.Column="0" Width="800" CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <WrapPanel x:Name="listaCondiciones" Orientation="Vertical" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"></WrapPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="Guardar" Margin="100,40,200,40" Grid.Row="0" Grid.Column="0" 
    Click="Guardar_Click">Guardar</Button>

            <Button x:Name="Cerrar" Margin="100,40,200,40" Grid.Row="0" Grid.Column="1" 
    Click="Cerrar_Click">Cancelar</Button>
        </Grid>
        
    </Grid>
</Window>
