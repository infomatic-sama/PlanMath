<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        xmlns:Controles="clr-namespace:ProcessCalc.Controles" x:Class="ProcessCalc.Ventanas.ConfigEntrada"
        mc:Ignorable="d"
        Title="Configuración de la variable o vector de entrada" Height="250" Width="500" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <StackPanel Orientation="Horizontal">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        
        <Controles:EntradaEspecifica x:Name="ctrlEntrada" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

        <Button x:Name="cerrar" HorizontalAlignment="Center" Grid.Column="0" Grid.Row="1" MaxWidth="200" Padding="10" Margin="10" Click="cerrar_Click">Cerrar</Button>
    </Grid>
    </StackPanel>
    </ScrollViewer>
</Window>
