<Window x:Class="ProcessCalc.Ventanas.OpcionesArrastreAgrupadores"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Opciones de arrastre de agrupadores" Height="450" Width="800" SizeToContent="WidthAndHeight" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <RadioButton x:Name="opcionAgrupadorArrastreContenidoAgrupadorSeleccionadoContenedor" IsChecked="True" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" Checked="opcionAgrupadorArrastreContenidoAgrupadorSeleccionadoContenedor_Checked"></RadioButton>
        <RadioButton x:Name="opcionAgrupadorSeleccionadoContenidoAgrupadorArrastreContenedor" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" Checked="opcionAgrupadorSeleccionadoContenidoAgrupadorArrastreContenedor_Checked"></RadioButton>

        <Button x:Name="aceptar" Grid.Column="0" Grid.Row="2" Margin="10" Click="aceptar_Click">Aceptar</Button>
        <Button x:Name="cancelar" Grid.Column="1" Grid.Row="2" Margin="10" Click="cancelar_Click">Cancelar</Button>
    </Grid>
</Window>
