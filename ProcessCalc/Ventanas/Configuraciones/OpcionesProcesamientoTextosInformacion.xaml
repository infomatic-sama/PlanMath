<Window x:Class="ProcessCalc.Ventanas.OpcionesProcesamientoTextosInformacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Opciones de lógica de procesamiento de cadenas de texto" Height="450" Width="800" SizeToContent="WidthAndHeight" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="opcionLogicasTextosAntes_EjecucionOperacion" Margin="10" Grid.Column="0" Grid.Row="0" Checked="opcionLogicasTextosAntes_EjecucionOperacion_Checked" Unchecked="opcionLogicasTextosAntes_EjecucionOperacion_Unchecked">Ejecutar estas lógicas durante la operación (por cada cantidad).</CheckBox>
            <CheckBox x:Name="opcionLogicasTextoDespues_EjecucionOperacion" Margin="10" Grid.Column="0" Grid.Row="1" Checked="opcionLogicasTextoDespues_EjecucionOperacion_Checked" Unchecked="opcionLogicasTextoDespues_EjecucionOperacion_Unchecked">Ejecutar estas lógicas al obtener resultados (por cada resultado).</CheckBox>

        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">Estas condiciones si/entonces con sus efectos en la variable o vector se ejecutarán en el orden establecido:</TextBlock>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="Agregar" Grid.Column="0" Margin="10" Padding="10" MaxWidth="150" HorizontalAlignment="Left" Click="Agregar_Click">Agregar condición</Button>
            <Button x:Name="Editar" Grid.Column="1" Margin="10" Padding="10" MaxWidth="150" HorizontalAlignment="Left" Click="Editar_Click" >Editar condición</Button>
            <Button x:Name="Quitar" Grid.Column="2" Margin="10" Padding="10" MaxWidth="150" HorizontalAlignment="Left" Click="Quitar_Click" >Quitar condición</Button>
            <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierda_Click" >Subir condición</Button>
            <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerecha_Click" >Bajar condición</Button>
        </Grid>

        <ScrollViewer Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel x:Name="condicionesProcesamientoTextosInformacion" Orientation="Vertical"></StackPanel>
        </ScrollViewer>

        <CheckBox x:Name="opcionNoConservarCambiosProcesamientoTextosInformacion" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Visibility="Collapsed" Margin="10" Checked="opcionNoConservarCambiosProcesamientoTextosInformacion_Checked" Unchecked="opcionNoConservarCambiosProcesamientoTextosInformacion_Unchecked">No conservar los cambios de esta lógica en las variables o vectores conectados a esta variable o vector</CheckBox>
        <CheckBox x:Name="opcionAplicarProcesamientoAntesImplicacionesTextosInformacion" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="10" Checked="opcionAplicarProcesamientoAntesImplicacionesTextosInformacion_Checked" Unchecked="opcionAplicarProcesamientoAntesImplicacionesTextosInformacion_Unchecked">Aplicar esta lógica antes de ejecutar las lógicas de asignación de cadenas de texto con y sin implicaciones</CheckBox>
        <CheckBox x:Name="opcionAplicarProcesamientoDespuesImplicacionesTextosInformacion" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="10" Checked="opcionAplicarProcesamientoDespuesImplicacionesTextosInformacion_Checked" Unchecked="opcionAplicarProcesamientoDespuesImplicacionesTextosInformacion_Unchecked">Aplicar esta lógica después de ejecutar las lógicas de asignación de cadenas de texto con y sin implicaciones</CheckBox>

        <Button x:Name="Cancelar" Grid.Column="0" Grid.Row="7" Margin="10" Padding="10" MaxWidth="100" Click="Cancelar_Click">Cancelar</Button>
        <Button x:Name="Guardar" Grid.Column="1" Grid.Row="7" Margin="10" Padding="10" MaxWidth="100" Click="Guardar_Click">Guardar</Button>
    </Grid>
</Window>
