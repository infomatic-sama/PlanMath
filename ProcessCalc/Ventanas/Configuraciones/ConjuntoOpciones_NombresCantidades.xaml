<Window x:Class="ProcessCalc.Ventanas.ConjuntoOpciones_NombresCantidades"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Lógica de nombres de variables de números" Height="450" Width="1100" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" Name="MyWindow" Loaded="MyWindow_Loaded">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="10">Cadena de texto compuesta para nombres de todos los números:</TextBlock>
                <Grid Name="opcionesDefiniciones" Grid.Row="0" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="opcionDefinicionNombresAntesEjecucion" Grid.Column="0" Grid.Row="0" Margin="10" Checked="opcionDefinicionNombresAntesEjecucion_Checked" Unchecked="opcionDefinicionNombresAntesEjecucion_Unchecked">Definir nombres antes de la ejecución de la variable o vector</CheckBox>
                    <CheckBox x:Name="opcionDefinicionNombresDuranteEjecucion" Grid.Column="0" Grid.Row="1" Margin="10" Checked="opcionDefinicionNombresDuranteEjecucion_Checked" Unchecked="opcionDefinicionNombresDuranteEjecucion_Unchecked">Definir nombres durante la ejecución de la variable o vector</CheckBox>
                    <CheckBox x:Name="opcionDefinicionNombresDespuesEjecucion" Grid.Column="0" Grid.Row="2" Margin="10" Checked="opcionDefinicionNombresDespuesEjecucion_Checked" Unchecked="opcionDefinicionNombresDespuesEjecucion_Unchecked">Definir nombres después de la ejecución de la variable o vector</CheckBox>

                    <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="opcionEstablecerNombreNumerosCantidades" Grid.Row="0" Margin="10" Checked="opcionEstablecerNombreNumerosCantidades_Checked" Unchecked="opcionEstablecerNombreNumerosCantidades_Unchecked">Definir nombres para números de la variable o vector</CheckBox>
                        <CheckBox x:Name="opcionEstablecerNombreOperacion" Grid.Row="1" Margin="10" Checked="opcionEstablecerNombreOperacion_Checked" Unchecked="opcionEstablecerNombreOperacion_Unchecked">Definir nombres para la variable o vector</CheckBox>
                    </Grid>
                </Grid>
                
                <Grid Grid.Row="2" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Button x:Name="agregarTexto" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarTexto_Click" >Agregar cadena de texto</Button>
                    <Button x:Name="editarTexto" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarTexto_Click" >Editar cadena de texto</Button>
                    <Button x:Name="quitarTexto" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarTexto_Click" >Quitar cadena de texto</Button>
                    <Button x:Name="moverTextoAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverTextoAIzquierda_Click" >Mover cadena de texto a izquierda</Button>
                    <Button x:Name="moverTextoADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverTextoADerecha_Click" >Mover cadena de texto a derecha</Button>

                </Grid>


            </Grid>

            <WrapPanel x:Name="listaTextos" MaxWidth="{Binding ElementName=MyWindow,Path=Width}" Orientation="Vertical" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto"></WrapPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Button x:Name="btnGuardar" Margin="10" Grid.Column="0" HorizontalAlignment="Center" Padding="10" Click="btnGuardar_Click">Guardar</Button>
                <Button x:Name="btnCerrar" Margin="10" Grid.Column="1" HorizontalAlignment="Center" Padding="10" Click="btnCerrar_Click">Cancelar</Button>
            </Grid>
            
        </StackPanel>
    </ScrollViewer>
</Window>
