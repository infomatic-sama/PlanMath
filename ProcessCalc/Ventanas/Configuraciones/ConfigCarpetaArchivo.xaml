<Window x:Class="ProcessCalc.Ventanas.ConfigCarpetaArchivo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Configuración de carpeta y archivo" Height="300" Width="800" WindowStyle="ToolWindow" ResizeMode="NoResize" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <RadioButton x:Name="opcionArchivoFijo" Grid.Row="0" Grid.Column="0" Margin="10" VerticalAlignment="Center" Checked="opcionArchivoFijo_Checked" Unchecked="opcionArchivoFijo_Unchecked">Utilizar el archivo indicado</RadioButton>
            <RadioButton x:Name="opcionSeleccionarArchivo" Grid.Row="0" Grid.Column="1" Margin="10" VerticalAlignment="Center" Checked="opcionSeleccionarArchivo_Checked" Unchecked="opcionSeleccionarArchivo_Unchecked">Seleccionar archivo en la ejecución</RadioButton>
            <RadioButton x:Name="opcionSeleccionarArchivoPorEntrada" Grid.Row="1" Grid.ColumnSpan="3" VerticalContentAlignment="Center" Margin="10" Checked="opcionSeleccionarArchivoPorEntrada_Checked" Unchecked="opcionSeleccionarArchivoPorEntrada_Unchecked">Elegir seleccionar archivo en la ejecución, por cada variable o vector de entrada</RadioButton>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Label x:Name="textoCarpeta" Grid.Row="0" Grid.Column="0" Margin="10" VerticalAlignment="Center">Carpeta:</Label>
            <RadioButton x:Name="opcionCarpetaFija" Grid.Row="1" Grid.Column="1" Margin="10" VerticalAlignment="Center" Checked="opcionCarpetaFija_Checked" Unchecked="opcionCarpetaFija_Unchecked">Especifica seleccionada</RadioButton>
            <RadioButton x:Name="opcionCarpetaArchivoCalculo" Grid.Row="1" Grid.Column="0" Margin="10" VerticalAlignment="Center" Checked="opcionCarpetaArchivoCalculo_Checked" Unchecked="opcionCarpetaArchivoCalculo_Unchecked">Del archivo de cálculo en el momento de la ejecución</RadioButton>
        </Grid>
        <Button x:Name="cerrar" Grid.Row="2" Margin="10" Width="100" HorizontalAlignment="Right" Click="cerrar_Click">Cerrar</Button>
    </Grid>
</Window>
