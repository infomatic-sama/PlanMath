<Window x:Class="ProcessCalc.Ventanas.ConfigSeleccionCantidades_Entrada"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Configuración de selección de números de la variable o vector de entrada" Height="450" Width="1000" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition ></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Margin="10">Definición de lógica de selección de números:</TextBlock>
        <RadioButton x:Name="opcionTodosNumeros" Grid.Row="1" Grid.Column="0" Margin="10" GroupName="Opciones" VerticalAlignment="Center" Checked="opcionTodosNumeros_Checked">Seleccionar todos los números obtenidos de la variable o vector</RadioButton>
        <RadioButton x:Name="opcionCantidadNumerosDeterminada" Grid.Row="2" Grid.Column="0" Margin="10"  GroupName="Opciones" VerticalAlignment="Center" Checked="opcionCantidadNumerosDeterminada_Checked">Seleccionar la siguiente cantidad de números obtenidos de la variable o vector:</RadioButton>
        <TextBox x:Name="cantidadNumeros" Grid.Row="2" Grid.Column="1" Margin="150,0,150,0" VerticalAlignment="Center" TextChanged="cantidadNumeros_TextChanged"></TextBox>

        <Grid x:Name="opcionesPosicionesIniciales" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <RadioButton x:Name="opcionPosicionInicialDeterminada" Grid.Row="0" Grid.Column="0" Margin="10"  GroupName="OpcionesPosicionesIniciales" VerticalAlignment="Center" Checked="opcionPosicionInicialDeterminada_Checked">Posición inicial del número del vector en la ejecución:</RadioButton>
            <TextBox x:Name="posicionInicial" Grid.Row="0" Grid.Column="1" Margin="150,0,150,0" VerticalAlignment="Center" TextChanged="posicionInicial_TextChanged"></TextBox>

            <RadioButton x:Name="opcionPosicionInicialUltimaEjecucion" Grid.Row="1" Grid.Column="0" Margin="10" GroupName="OpcionesPosicionesIniciales" VerticalAlignment="Center" Checked="opcionPosicionInicialUltimaEjecucion_Checked">Posición inicial del número del vector en la última ejecución</RadioButton>
            <RadioButton x:Name="opcionPosicionFinalUltimaEjecucion" Grid.Row="2" Grid.Column="0" Margin="10" GroupName="OpcionesPosicionesIniciales" VerticalAlignment="Center" Checked="opcionPosicionFinalUltimaEjecucion_Checked">Posición final del número del vector en la última ejecución</RadioButton>

        </Grid>
        
        <CheckBox x:Name="opcionNumerosCondicion" Grid.Row="4" Grid.Column="0" Margin="10" VerticalAlignment="Center" Checked="opcionNumerosCondicion_Checked" Unchecked="opcionNumerosCondicion_Unchecked">Seleccionar los números que cumplan las condiciones si/entonces:</CheckBox>

        <Grid x:Name="estructuraCondiciones" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="5" Margin="10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition ></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition ></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Condiciones si/entonces:</TextBlock>

            <Grid Grid.Row="1" Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar</Button>
                <Button x:Name="editarCondicion" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicion_Click">Editar</Button>
                <Button x:Name="quitarCondicion" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicion_Click" >Quitar</Button>
                <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierda_Click" >Mover a izquierda</Button>
                <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerecha_Click">Mover a derecha</Button>

            </Grid>

            <ScrollViewer x:Name="contenedorListaCondiciones" Grid.Row="2" Grid.Column="0" Width="800" CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <WrapPanel x:Name="listaCondiciones" Orientation="Vertical" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"></WrapPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="6" Margin="10" VerticalAlignment="Center">Seleccionar la dirección y sentido de captura de cantidades <LineBreak></LineBreak>(se inicia desde la posición inicial seleccionada):</TextBlock>

        <Grid Grid.Row="6" Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <RadioButton x:Name="opcionDireccionSentidoHaciaAdelante" Margin="10" Grid.Row="0" GroupName="OpcionesDireccionSentido" IsChecked="True" Checked="opcionDireccionSentidoHaciaAdelante_Checked">Del más antiguo al más reciente (hacia adelante)</RadioButton>
            <RadioButton x:Name="opcionDireccionSentidoHaciaAtras" Margin="10" Grid.Row="1" GroupName="OpcionesDireccionSentido" Checked="opcionDireccionSentidoHaciaAtras_Checked">Del más reciente al más antiguo (hacia atrás)</RadioButton>
        </Grid>

        <Grid x:Name="opcionesEjecucion" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" Margin="10">Configuración de esta definición de lógica de selección de números:</TextBlock>
            <RadioButton x:Name="opcionDefinicionAutomatica" Margin="10" Grid.Column="0" Grid.Row="1" GroupName="OpcionesEjecucion" VerticalAlignment="Center" Checked="opcionDefinicionAutomatica_Checked">Usar esta definición de configuración automáticamente en cada ejecución</RadioButton>
            <RadioButton x:Name="opcionDefinicionManual" Margin="10" Grid.Column="0" Grid.Row="2" GroupName="OpcionesEjecucion" VerticalAlignment="Center" Checked="opcionDefinicionManual_Checked">Definir esta definición de configuración en cada ejecución</RadioButton>

            <TextBlock Grid.Column="0" Grid.Row="3" Margin="10">Usar la definición manual de configuración, 
    <LineBreak></LineBreak>luego seguir con la definición automática cuando:
            </TextBlock>

            <RadioButton x:Name="opcionDefinicionAlternada" Margin="10" Grid.Column="0" Grid.Row="4" GroupName="OpcionesEjecucion" VerticalAlignment="Center" Visibility="Collapsed" Checked="opcionDefinicionAlternada_Checked">Haya un cambio en el origen de datos de la variable o vector</RadioButton>
            <RadioButton x:Name="opcionDefinicionAlternada_Condiciones" Margin="10" Grid.Column="0" Grid.Row="5" GroupName="OpcionesEjecucion" VerticalAlignment="Center" Checked="opcionDefinicionAlternada_Condiciones_Checked" >Se cumplan las condiciones si/entonces</RadioButton>
            <RadioButton x:Name="opcionDefinicionAlternada_Condiciones_NoCumplan" Margin="10" Grid.Column="0" Grid.Row="6" GroupName="OpcionesEjecucion" VerticalAlignment="Center" Checked="opcionDefinicionAlternada_Condiciones_NoCumplan_Checked" >No se cumplan las condiciones si/entonces</RadioButton>
        </Grid>

        <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="Guardar" Margin="100,40,200,40" Grid.Row="0" Grid.Column="0" 
        Click="Guardar_Click">Guardar</Button>

            <Button x:Name="Cancelar" Margin="100,40,200,40" Grid.Row="0" Grid.Column="1" 
        Click="Cerrar_Click">Cancelar</Button>
        </Grid>
        
    </Grid>
</Window>
