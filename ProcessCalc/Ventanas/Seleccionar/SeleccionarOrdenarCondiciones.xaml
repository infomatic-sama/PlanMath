<Window xmlns:Condiciones="clr-namespace:ProcessCalc.Controles.Condiciones"  x:Class="ProcessCalc.Ventanas.SeleccionarOrdenarCondiciones"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Definir lógica con condiciones si/entonces para seleccionar variables o vectores retornados" Height="450" Width="800" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid x:Name="opcionManual" Visibility="Collapsed" Grid.Row="0" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>

            <CheckBox x:Name="opcionModoManual" Margin="10" Grid.Row="0" Checked="opcionModoManual_Checked" Unchecked="opcionModoManual_Unchecked">Modo de lógica de selección manual de variables o vectores</CheckBox>
            <TextBlock Margin="10,0,10,10" Grid.Row="1">Este modo hace que el usuario o el software en la ejecución seleccione manualmente las variables o vectores posteriores al continuar con la ejecución del cálculo.</TextBlock>
        </Grid>

        <ScrollViewer x:Name="contenedorlistaTextos" Grid.Row="1" Grid.ColumnSpan="2" CanContentScroll="true" VerticalScrollBarVisibility="Auto" MaxHeight="600">
            <Condiciones:SeleccionOrdenamiento_Condiciones x:Name="listaCondiciones" />
        </ScrollViewer>

        <Grid x:Name="opcionesCondicionesAsignacionTextosInformacion" Grid.Row="2" Grid.ColumnSpan="2" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="10">Definición de lógica de asignación de cadenas de texto:</TextBlock>
            <CheckBox x:Name="opcionIncluirAsignacionTextosInformacionAntes" Grid.Row="1" VerticalContentAlignment="Center" Margin="10">
                <TextBlock>Incluir la lógica de asignación de cadenas de texto antes de la ejecución de las condiciones si/entonces de esta lógica.
                    <LineBreak></LineBreak>(Se filtrarán solo los números que cumplan las condiciones si/entonces)
                </TextBlock>
            </CheckBox>
            <CheckBox x:Name="opcionIncluirAsignacionTextosInformacionDespues" Grid.Row="2" Margin="10">Incluir la lógica de asignación de cadenas de texto después de la ejecución de las condiciones si/entonces de esta lógica.</CheckBox>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnCerrar" Margin="10" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" MaxWidth="100" Click="btnCerrar_Click">Guardar</Button>
            <Button x:Name="btnCancelar" Margin="10" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" MaxWidth="100" Click="btnCancelar_Click">Cancelar</Button>
        </Grid>
        
   </Grid>
</Window>
