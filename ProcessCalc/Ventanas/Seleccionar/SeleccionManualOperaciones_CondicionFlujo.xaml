<Window x:Class="ProcessCalc.Ventanas.SeleccionManualOperaciones_CondicionFlujo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Seleccionar manualmente las próximas variables o vectores" Height="450" Width="800" Loaded="Window_Loaded" WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="titulo" Margin="10" TextWrapping="Wrap" FontSize="15" Grid.Row="0">Seleccionar próximas variables o vectores para continuar <LineBreak/>Ejecución del cálculo NombreCalculo.pmcalc</TextBlock>
        <TextBlock x:Name="descripcionCondiciones" Grid.Row="1" Margin="10" TextWrapping="Wrap">Operador de lógica</TextBlock>

        <ScrollViewer Grid.Row="3" Height="250" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Grid  Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <!--<ScrollViewer x:Name="ListaNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="250" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">-->
                <StackPanel x:Name="listaOperaciones" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="10" Orientation="Vertical">

                </StackPanel>
                <!--</ScrollViewer>-->
                <!--<ScrollViewer x:Name="TextoNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="250" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">-->
                
                <!--</ScrollViewer>-->
            </Grid>
        </ScrollViewer>
        <Grid Grid.Row="4" HorizontalAlignment="Right" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnDetener" Grid.Column="1" Margin="10" Padding="5" Click="btnDetener_Click">Detener</Button>
            <Button x:Name="btnContinuar" Grid.Column="2" Margin="10" Padding="5" Click="btnContinuar_Click">Seleccionar variables o vectores</Button>
        </Grid>
    </Grid>
</Window>
