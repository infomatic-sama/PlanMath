<Window x:Class="ProcessCalc.Ventanas.SeleccionarOrdenarCantidades_Operador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas" xmlns:textosinformacion="clr-namespace:ProcessCalc.Controles.TextosInformacion"
        mc:Ignorable="d"
        Title="Lógica de seleccionar y ordenar números" Height="450" Width="800" WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid x:Name="opcionSeleccionManual" Visibility="Collapsed" Grid.Row="0" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <CheckBox x:Name="opcionModoSeleccionManual" Margin="10" Grid.Row="0" Checked="opcionModoSeleccionManual_Checked" Unchecked="opcionModoSeleccionManual_Unchecked" >Modo lógica de selección manual de números</CheckBox>
                <TextBlock Margin="10,0,10,10" Grid.Row="1">Este modo hace que en la ejecución, el usuario o el software seleccione los números manualmente y luego las une.</TextBlock>
            </Grid>

            <Grid x:Name="opcionUnir" Visibility="Collapsed" Grid.Row="1" Grid.ColumnSpan="2">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <CheckBox x:Name="opcionModoUnir" Margin="10" Grid.Row="0" Checked="opcionModoUnir_Checked" Unchecked="opcionModoUnir_Unchecked">Modo de lógica de unir números</CheckBox>
                <TextBlock Margin="10,0,10,10" Grid.Row="1">Este modo hace que la lógica de ejecución del software una todos los números de sus variables o vectores en un solo vector retornado.</TextBlock>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10" Padding="5" Grid.Row="0" Grid.Column="0">Establece las cadenas de texto según condiciones si/entonces:</TextBlock>

                <Button x:Name="btnDefinirAsignacionImplicacionTextos" Margin="10" Grid.Row="0" Grid.Column="1" Padding="5" MaxWidth="700" HorizontalContentAlignment="Left" Click="btnDefinirAsignacionImplicacionTextos_Click" >
                    <Button.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition></ColumnDefinition>
                                <ColumnDefinition></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <Image Source="/ProcessCalc;component/Imagenes/Iconos4/12.png" Grid.Column="0" Width="24" Height="24"></Image>
                            <Label Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">Lógicas de asignaciones de cadenas de texto</Label>
                        </Grid>
                    </Button.Content>
                </Button>
            </Grid>
            <ScrollViewer x:Name="contenedorlistaTextos" Grid.Row="3" CanContentScroll="true" VerticalScrollBarVisibility="Auto" MaxHeight="600">
                <textosinformacion:SeleccionOrdenamientoCondiciones_TextosInformacion x:Name="listaTextos" ></textosinformacion:SeleccionOrdenamientoCondiciones_TextosInformacion>
            </ScrollViewer>

            <Grid x:Name="opcionesCondicionesAsignacionTextosInformacion" Grid.Row="4" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="10">Definición de lógica de asignación de cadenas de texto:</TextBlock>
                <CheckBox x:Name="opcionIncluirAsignacionTextosInformacionAntes" Grid.Row="1" VerticalContentAlignment="Center" Margin="10">
                    <TextBlock>Incluir la ejecución de las lógicas de asignación de cadenas de texto antes de la ejecución de las condiciones si/entonces de esta lógica.
                    <LineBreak></LineBreak>(Luego se filtrarán solo los números que cumplan las condiciones si/entonces)
                    </TextBlock>
                </CheckBox>
                <CheckBox x:Name="opcionIncluirAsignacionTextosInformacionDespues" Grid.Row="2" Margin="10">Incluir la ejecución de la lógica de asignación de cadenas de texto después de la ejecución de las condiciones si/entonces de esta lógica.</CheckBox>
            </Grid>

            <Grid Grid.Row="5" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnContinuar" Margin="10" Grid.Row="0" Grid.Column="1" MaxWidth="100" Click="btnContinuar_Click">Guardar lógica</Button>
                <Button x:Name="btnCancelar" Margin="10" Grid.Row="0" Grid.Column="0" MaxWidth="100" Click="btnCancelar_Click">Cancelar</Button>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
