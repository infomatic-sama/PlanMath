<Window x:Class="ProcessCalc.Ventanas.SeleccionarDefinicion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Seleccionar tipo de lógica para la variable o vector" Height="450" Width="800" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <RadioButton x:Name="optDefinicionSimple" Margin="10" Padding="50,0,50,0" Grid.Row="1" Grid.ColumnSpan="2" Checked="optDefinicionSimple_Checked" IsChecked="True" HorizontalAlignment="Left">Lógica normal</RadioButton>
        <RadioButton x:Name="optDefinicionNormal" Margin="10" Padding="50,0,50,0" Grid.Row="2" Grid.ColumnSpan="2" Checked="optDefinicionNormal_Checked" HorizontalAlignment="Left">Lógica interna (tiene lógicas internas que se definen)</RadioButton>
        
        <Button x:Name="btnContinuar" Margin="10" Grid.Row="3" Grid.Column="1" MaxWidth="100" Click="btnContinuar_Click">Definir lógica</Button>
        <Button x:Name="btnCancelar" Margin="10" Grid.Row="3" Grid.Column="0" MaxWidth="100" Click="btnCancelar_Click">Cancelar</Button>
    </Grid>
</Window>
