<Window x:Class="ProcessCalc.Ventanas.SeleccionarOpcionesDeshacerAgrupador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Deshacer agrupador" Height="450" Width="800" ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <CheckBox x:Name="opcionQuitarElementosCalculo" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">Quitar las variables o vectores del cálculo (no solo del agrupador)</CheckBox>
        <Button x:Name="cancelar" Margin="10" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Click="cancelar_Click">Cancelar</Button>
        <Button x:Name="deshacerAgrupador" Margin="10" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Right" Click="deshacerAgrupador_Click">Deshacer agrupador</Button>
    </Grid>
</Window>
