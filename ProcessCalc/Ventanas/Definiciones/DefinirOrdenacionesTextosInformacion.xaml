<Window x:Class="ProcessCalc.Ventanas.DefinirOrdenacionesTextosInformacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Definir ordenaciones parciales de cadenas de texto" Height="450" Width="1000" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <CheckBox x:Name="opcionInvertirListaTextos" Margin="10" Grid.Row="0" VerticalAlignment="Center" Grid.ColumnSpan="2" Checked="opcionInvertirListaTextos_Checked" Unchecked="opcionInvertirListaTextos_Unchecked">Revertir lista de cadenas de texto antes de dividir, combinar y ordenar</CheckBox>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10">Estas ordenaciones con sus efectos se ejecutarán en el orden establecido:</TextBlock>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="Agregar" Grid.Column="0" Margin="10" Padding="10" MaxWidth="250" HorizontalAlignment="Left" Click="Agregar_Click">Agregar división de ordenación</Button>
            <Button x:Name="Quitar" Grid.Column="1" Margin="10" Padding="10" MaxWidth="250" HorizontalAlignment="Left" Click="Quitar_Click" >Quitar división de ordenación</Button>
            <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="2" Margin="10" Click="moverCondicionAIzquierda_Click" >Subir división de ordenación</Button>
            <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionADerecha_Click" >Bajar división de ordenación</Button>
        </Grid>

        <ScrollViewer Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
            <StackPanel x:Name="ordenaciones" Orientation="Vertical"></StackPanel>
        </ScrollViewer>

        <Button x:Name="Cancelar" Grid.Column="0" Grid.Row="4" Margin="10" Padding="10" MaxWidth="100" Click="Cancelar_Click">Cancelar</Button>
        <Button x:Name="Guardar" Grid.Column="1" Grid.Row="4" Margin="10" Padding="10" MaxWidth="100" Click="Guardar_Click">Guardar</Button>
    </Grid>
</Window>
