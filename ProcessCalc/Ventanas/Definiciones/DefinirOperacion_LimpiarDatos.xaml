<Window x:Class="ProcessCalc.Ventanas.Definiciones.DefinirOperacion_LimpiarDatos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas.Definiciones"
        mc:Ignorable="d"
        Title="Definir lógica de limpiar datos" Height="600" Width="800" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid x:Name="opcionesImplicaciones" Visibility="Collapsed" Grid.Row="0" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="opcionImplicacionesAntes" Grid.Column="0" Margin="10" Padding="5" VerticalContentAlignment="Center" Checked="opcionImplicacionesAntes_Checked" Unchecked="opcionImplicacionesAntes_Unchecked">Ejecutar las lógicas de asignaciones de cadenas de texto antes de la limpieza</CheckBox>
            <CheckBox x:Name="opcionImplicacionesDurante" Grid.Column="1" Margin="10" Padding="5" VerticalContentAlignment="Center" Checked="opcionImplicacionesDurante_Checked" Unchecked="opcionImplicacionesDurante_Unchecked">Ejecutar las lógicas de asignaciones de cadenas de texto durante la limpieza (en cada número)</CheckBox>
            <CheckBox x:Name="opcionImplicacionesDespues" Grid.Column="2" Margin="10" Padding="5" VerticalContentAlignment="Center" Checked="opcionImplicacionesDespues_Checked" Unchecked="opcionImplicacionesDespues_Unchecked">Ejecutar las lógicas de asignaciones de cadenas de texto después de la limpieza</CheckBox>
        </Grid>

        <CheckBox x:Name="opcionQuitarDuplicados" Margin="10" Grid.Row="1" Grid.Column="0" Checked="opcionQuitarDuplicados_Checked" Unchecked="opcionQuitarDuplicados_Unchecked">Quitar duplicadas</CheckBox>

        <Grid x:Name="opcionesDuplicados" Visibility="Collapsed" Grid.Row="2" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Opciones de duplicados</TextBlock>
            <CheckBox x:Name="opcionQuitarCantidadesDuplicadas" Margin="10" Grid.Row="1" Grid.Column="0">Quitar números duplicados</CheckBox>
            <ComboBox x:Name="opcionConector1_Duplicados" Grid.Row="2" Grid.Column="0" Margin="10">
                <ComboBoxItem IsSelected="True" Uid="2">Y</ComboBoxItem>
                <ComboBoxItem Uid="3">O</ComboBoxItem>
            </ComboBox>
            <CheckBox x:Name="opcionQuitarCantidadesTextosDuplicadas" Margin="10" Grid.Row="3" Grid.Column="0">Quitar cantidades con textos de información duplicados en relación a otras cantidades</CheckBox>
            <ComboBox x:Name="opcionConector2_Duplicados" Grid.Row="4" Grid.Column="0" Margin="10">
                <ComboBoxItem IsSelected="True" Uid="2">Y</ComboBoxItem>
                <ComboBoxItem Uid="3">O</ComboBoxItem>
            </ComboBox>
            <CheckBox x:Name="opcionQuitarCantidadesTextosDentroDuplicados" Margin="10" Grid.Row="5" Grid.Column="0">Quitar números con cadenas de texto duplicadas dentro de la misma números</CheckBox>
        </Grid>

        <CheckBox x:Name="opcionQuitarCeros" Margin="10" Grid.Row="3" Grid.Column="0" Checked="opcionQuitarCeros_Checked" Unchecked="opcionQuitarCeros_Unchecked">Quitar ceros</CheckBox>

        <Grid x:Name="opcionesCeros" Visibility="Collapsed" Grid.Row="4" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Opciones de ceros</TextBlock>
            <CheckBox x:Name="opcionQuitarCerosConTextos" Margin="10" Grid.Row="1" Grid.Column="0">Quitar ceros con cadenas de texto</CheckBox>
            <ComboBox x:Name="opcionConector1_Ceros" Grid.Row="2" Grid.Column="0" Margin="10">
                <ComboBoxItem IsSelected="True" Uid="2">Y</ComboBoxItem>
                <ComboBoxItem Uid="3">O</ComboBoxItem>
            </ComboBox>
            <CheckBox x:Name="opcionQuitarCerosSinTextos" Margin="10" Grid.Row="3" Grid.Column="0">Quitar ceros sin cadenas de texto</CheckBox>
        </Grid>

        <CheckBox x:Name="opcionQuitarCantidadesSinTextos" Margin="10" Grid.Row="5" Grid.Column="0">Quitar números sin cadenas de texto</CheckBox>

        <CheckBox x:Name="opcionQuitarNegativas" Margin="10" Grid.Row="6" Grid.Column="0">Quitar números negativos</CheckBox>

        <StackPanel x:Name="operandosSalidas" Grid.Row="7" Grid.Column="0" CanHorizontallyScroll="True" CanVerticallyScroll="True" Orientation="Horizontal">

        </StackPanel>

        <Grid Grid.Row="8" Grid.Column="0" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button x:Name="guardar" Margin="10" Grid.Column="0" Click="guardar_Click">Guardar</Button>
            <Button x:Name="cancelar" Margin="10" Grid.Column="1" Click="cancelar_Click">Cancelar</Button>
        </Grid>
    </Grid>
</Window>
