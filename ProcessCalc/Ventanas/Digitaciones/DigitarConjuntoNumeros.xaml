<Window x:Class="ProcessCalc.Ventanas.DigitarConjuntoNumeros"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc"
        mc:Ignorable="d"
        Title="Digitar vector de números" Height="550" Width="900" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Icon="/ProcessCalc;component/Imagenes/03.png">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="titulo" Margin="10" TextWrapping="Wrap" FontSize="15" Grid.Row="0">Digitar vector de números de entrada <LineBreak/>Ejecución del cálculo NombreCalculo.pmcalc</TextBlock>
        <TextBlock x:Name="descripcionEntrada" Grid.Row="1" Margin="10" TextWrapping="Wrap">Descripción del vector de números de entrada</TextBlock>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="vistaOpcionLista" Margin="10" Grid.Column="0" Grid.Row="0" Click="vistaOpcionLista_Click">
                <Button.Content>
                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/22.png" Height="24" Width="24" Grid.Column="0"></Image>
                </Button.Content>
            </Button>
            <Button x:Name="vistaOpcionTexto" Margin="10" Grid.Column="1" Grid.Row="0" Click="vistaOpcionTexto_Click">
                <Button.Content>
                    <Image Source="/ProcessCalc;component/Imagenes/Iconos4/23.png" Height="24" Width="24" Grid.Column="0"></Image>
                </Button.Content>
            </Button>

        </Grid>
        <ScrollViewer Grid.Row="3" Height="250" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Grid  Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <!--<ScrollViewer x:Name="ListaNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="250" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">-->
                <StackPanel x:Name="listaNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="10" Orientation="Vertical">

                </StackPanel>
                <!--</ScrollViewer>-->
                <!--<ScrollViewer x:Name="TextoNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="250" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">-->
                <StackPanel x:Name="textoNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Margin="10" Orientation="Vertical" Visibility="Collapsed">
                    <TextBlock>El separador entre cadenas de texto y el número es el punto y coma. Cada línea es un número.<LineBreak/>Primero se escriben el nombre del número, las cadenas de texto y luego el número, escritos de izquierda a derecha separados por punto y coma.<LineBreak/>Para escribir el siguiente número, se avanza a la siguiente línea del texto.</TextBlock>
                    <TextBox x:Name="listaTextoNumeros" TextWrapping="Wrap" AcceptsReturn="True" TextChanged="listaTextoNumeros_TextChanged"/>
                </StackPanel>
                <!--</ScrollViewer>-->
            </Grid>
        </ScrollViewer>
        <Grid Grid.Row="4" HorizontalAlignment="Right" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnPausar" Grid.Column="1" Margin="10" Padding="5" Click="btnPausar_Click">Ingresar y pausar</Button>
            <Button x:Name="btnDetener" Grid.Column="0" Margin="10" Padding="5" Click="btnDetener_Click">Detener</Button>
            <Button x:Name="btnContinuar" Grid.Column="2" Margin="10" Padding="5" Click="btnContinuar_Click">Ingresar y continuar</Button>
        </Grid>
    </Grid>
</Window>
