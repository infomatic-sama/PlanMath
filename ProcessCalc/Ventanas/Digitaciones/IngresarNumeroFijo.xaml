<Window xmlns:Ctrl_Entradas="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"  x:Class="ProcessCalc.Ventanas.IngresarNumeroFijo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc"
        mc:Ignorable="d"
        Title="Ingresar variable de número" MaxHeight="500" Height="250" Width="405" MinWidth="405" WindowStartupLocation="CenterScreen" ShowInTaskbar="True" WindowStyle="ToolWindow" Icon="/ProcessCalc;component/Imagenes/03.png" SizeToContent="WidthAndHeight">
    <StackPanel CanVerticallyScroll="True">
        <TextBox x:Name="txtNumero" Padding="10" Margin="20,10" TextAlignment="Center" FontSize="16" >0</TextBox>
        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200" Height="Auto">
            <StackPanel CanVerticallyScroll="True">
                <Ctrl_Entradas:TextosEtiquetas_Entrada x:Name="textos" Width="Auto" Height="Auto" />
            </StackPanel>
        </ScrollViewer>
        <Button x:Name="btnUtilizar" Padding="10" Margin="20,10" Click="btnUtilizar_Click">Utilizar número</Button>
        <Button x:Name="btnCancelar" Padding="10" Margin="20,10" Click="btnCancelar_Click" >Cancelar</Button>
    </StackPanel>
</Window>
