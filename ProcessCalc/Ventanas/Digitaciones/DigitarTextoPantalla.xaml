<Window xmlns:Ctrl_Entradas="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"  x:Class="ProcessCalc.Ventanas.DigitarTextoPantalla"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc"
        mc:Ignorable="d"
        Title="Digitar texto en pantalla" Height="300" Width="500" MaxWidth="1000" MaxHeight="1000" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Icon="/ProcessCalc;component/Imagenes/03.png" SizeToContent="WidthAndHeight">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="titulo" Margin="10" TextWrapping="Wrap" FontSize="15" Grid.Row="0">Digitar texto en pantalla de entrada <LineBreak/>Ejecución del cálculo NombreCalculo.pmcalc</TextBlock>
        <TextBlock x:Name="descripcionEntrada" Grid.Row="1" Margin="10" TextWrapping="Wrap">Descripción de la entrada</TextBlock>
        <Grid Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="32" Width="32" Margin="10" ></Image>
            <TextBox x:Name="textoDigitado" Grid.Column="1" Margin="10" AcceptsReturn="True" TextWrapping="Wrap" TextChanged="textoDigitado_TextChanged" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
            
        </Grid>

        <Grid Grid.Row="4" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnPausar" Grid.Column="1" Margin="10" Padding="5" Click="btnPausar_Click">Ingresar y pausar</Button>
            <Button x:Name="btnDetener" Grid.Column="0" Margin="10" Padding="5" Click="btnDetener_Click">Detener</Button>
            <Button x:Name="btnContinuar" Grid.Column="2" Margin="10" Padding="5" Click="btnContinuar_Click">Ingresar y continuar</Button>
        </Grid>
    </Grid>
</Window>
