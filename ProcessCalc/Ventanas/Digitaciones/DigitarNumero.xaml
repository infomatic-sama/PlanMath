<Window xmlns:Ctrl_Entradas="clr-namespace:ProcessCalc.Controles.Ctrl_Entradas"  x:Class="ProcessCalc.Ventanas.DigitarNumero"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc"
        mc:Ignorable="d"
        Title="Digitar variable de número" Height="300" Width="500" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Icon="/ProcessCalc;component/Imagenes/03.png" SizeToContent="WidthAndHeight">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="titulo" Margin="10" TextWrapping="Wrap" FontSize="15" Grid.Row="0">Digitar variable de número de entrada <LineBreak/>Ejecución del cálculo NombreCalculo.pmcalc</TextBlock>
        <TextBlock x:Name="descripcionEntrada" Grid.Row="1" Margin="10" TextWrapping="Wrap">Descripción de la variable de número de entrada</TextBlock>
        <Grid Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Height="32" Width="32" Margin="10" Source="/ProcessCalc;component/Imagenes/20.png"></Image>
            <TextBox x:Name="numeroDigitado" Grid.Column="1" Margin="10" Visibility="Collapsed" TextWrapping="Wrap" TextChanged="numeroDigitado_TextChanged" />
            <ComboBox x:Name="opcionesNumeros" MinWidth="100" Margin="10" Grid.Column="1" Visibility="Visible" TextBoxBase.TextChanged="numeroDigitado_TextChanged" IsEditable="True"/>
            <ComboBox x:Name="opcionesListaNumeros" Margin="10" Grid.Column="1" Visibility="Collapsed" SelectionChanged="opcionesListaNumeros_SelectionChanged" TextBoxBase.TextChanged="opcionesListaNumeros_TextChanged"></ComboBox>
        </Grid>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" MaxHeight="200" Height="Auto">
            <StackPanel CanVerticallyScroll="True">
                <Ctrl_Entradas:TextosEtiquetas_Entrada x:Name="textos" Width="Auto" Height="Auto" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="4" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnPausar" Grid.Column="1" Margin="10" Padding="5" Click="btnPausar_Click">Ingresar y pausar</Button>
            <Button x:Name="btnDetener" Grid.Column="0" Margin="10" Padding="5" Click="btnDetener_Click">Detener</Button>
            <Button x:Name="btnContinuar" Grid.Column="2" Margin="10" Padding="5" Click="btnContinuar_Click">Ingresar y continuar</Button>
        </Grid>
    </Grid>
</Window>
