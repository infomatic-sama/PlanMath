<Window x:Class="ProcessCalc.Ventanas.EstablecerConjuntosTextosInformacionPredefinidos_Digitacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Establecer vectores de cadenas de texto predefinidos a digitar" Height="450" Width="800" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid x:Name="tituloParametros" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" FontWeight="Bold" Margin="10">Vectores de cadenas de texto predefinidos a seleccionar para digitar en el vector de entrada en ejecución:</TextBlock>
            
            <CheckBox x:Name="utilizarPrimerConjuntoAutomaticamente" Margin="10" Grid.Row="1" Checked="utilizarPrimerConjuntoAutomaticamente_Checked" Unchecked="utilizarPrimerConjuntoAutomaticamente_Unchecked">Utilizar el primer vector de forma automática en la digitación</CheckBox>
            <CheckBox x:Name="utilizarSoloTextosDeInformacionPredefinidos" Margin="10" Grid.Row="2" Checked="utilizarSoloTextosDeInformacionPredefinidos_Checked" Unchecked="utilizarSoloTextosDeInformacionPredefinidos_Unchecked">Utilizar sólo estas cadenas de texto predefinidas</CheckBox>
            
            <Grid x:Name="parametros" Grid.Row="3" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>
            </Grid>
        </Grid>

        <Button x:Name="continuar" Margin="10" Grid.Row="2" Grid.Column="1" MaxWidth="100" Padding="7" Click="continuar_Click">Cerrar</Button>
    </Grid>
</Window>
