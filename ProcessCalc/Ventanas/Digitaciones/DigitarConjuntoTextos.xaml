<Window xmlns:TextosInformacion="clr-namespace:ProcessCalc.Controles.TextosInformacion"  x:Class="ProcessCalc.Ventanas.DigitarConjuntoTextos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Digitar vector de cadenas de texto" Height="550" Width="900" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Icon="/ProcessCalc;component/Imagenes/03.png">
    <Grid Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="titulo" Margin="10" TextWrapping="Wrap" FontSize="15" Grid.Row="0">Digitar vector de cadenas de texto de entrada <LineBreak/>Ejecución del cálculo NombreCalculo.pmcalc</TextBlock>
        <TextBlock x:Name="descripcionEntrada" Grid.Row="1" Margin="10" TextWrapping="Wrap">Descripción del vector de cadenas de texto de entrada</TextBlock>

        
            <Grid  Grid.Row="2" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
            <Button x:Name="agregarFila" Margin="10" Grid.Row="0" MaxWidth="200" HorizontalAlignment="Left" Grid.Column="0" Padding="5" Click="agregarFila_Click">Agregar fila</Button>

            <ScrollViewer Grid.Column="0" Grid.Row="1" Height="250" HorizontalScrollBarVisibility="Auto" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}">
                <!--<ScrollViewer x:Name="ListaNumeros" Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" Height="250" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">-->
                <StackPanel x:Name="filasTextos" Orientation="Vertical" Margin="10" >

                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <Grid Grid.Row="3" HorizontalAlignment="Right" Background="{DynamicResource {x:Static SystemColors.GradientInactiveCaptionBrushKey}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnPausar" Grid.Column="1" Margin="10" Padding="5" Click="btnPausar_Click">Ingresar y pausar</Button>
            <Button x:Name="btnDetener" Grid.Column="0" Margin="10" Padding="5" Click="btnDetener_Click">Detener</Button>
            <Button x:Name="btnContinuar" Grid.Column="2" Margin="10" Padding="5" Click="btnContinuar_Click">Ingresar y continuar</Button>
        </Grid>
    </Grid>
</Window>
