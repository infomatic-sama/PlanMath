<Window x:Class="ProcessCalc.Ventanas.EstablecerCondiciones_TextosInformacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Establecer condiciones si/entonces para cadenas de texto" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded"
        Name="MyWindow">
    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">
            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Condiciones para la lógica de cadenas de texto:</TextBlock>
                <Grid Grid.Row="1" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>

                    <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar condición</Button>
                    <Button x:Name="editarCondicion" Grid.Row="0" Grid.Column="1" Margin="10" Click="editarCondicion_Click" >Editar condición</Button>
                    <Button x:Name="quitarCondicion" Grid.Row="0" Grid.Column="2" Margin="10" Click="quitarCondicion_Click" >Quitar condición</Button>
                    <Button x:Name="moverCondicionAIzquierda" Grid.Row="0" Grid.Column="3" Margin="10" Click="moverCondicionAIzquierda_Click" >Mover condición a izquierda</Button>
                    <Button x:Name="moverCondicionADerecha" Grid.Row="0" Grid.Column="4" Margin="10" Click="moverCondicionADerecha_Click" >Mover condición a derecha</Button>

                </Grid>


            </Grid>

            <WrapPanel x:Name="listaCondiciones" MaxWidth="{Binding ElementName=MyWindow,Path=Width}" Orientation="Vertical" Background="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto"></WrapPanel>

            <Button x:Name="btnCerrar" Margin="10"  HorizontalAlignment="Center" Padding="10" Click="btnCerrar_Click">Cerrar</Button>
        </StackPanel>
    </ScrollViewer>
</Window>