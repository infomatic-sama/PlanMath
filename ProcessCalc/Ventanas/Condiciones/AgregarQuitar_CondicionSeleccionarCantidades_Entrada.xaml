<Window x:Class="ProcessCalc.Ventanas.AgregarQuitar_CondicionSeleccionarCantidades_Entrada"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Definir lógica de búsquedas dentro de las entradas" Height="450" Width="800" WindowState="Maximized" Loaded="Window_Loaded">
    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock x:Name="textoElementoBusqueda" Grid.Row="1" Grid.Column="0" Margin="10">Elemento relacionado a esta lógica:</TextBlock>
            <ComboBox x:Name="elementoBusquedaRelacionadoCondicion" Grid.Row="1" Grid.Column="1" Margin="10">
                <ComboBoxItem Content="Cantidad de cadenas de texto obtenidas" Uid="1"/>
                <ComboBoxItem Content="Cantidad de números obtenidos del vector" Uid="2"/>
                <ComboBoxItem Content="Cantidad de cadenas de texto obtenidas de la última ejecución" Uid="3"/>
                <ComboBoxItem Content="Cantidad de números obtenidos del vector de la última ejecución" Uid="4"/>
                <ComboBoxItem Content="Posición del número obtenido del vector en la ejecución" Uid="6"/>
                <ComboBoxItem Content="Posición del número obtenido del vector en la última ejecución" Uid="7"/>
                <ComboBoxItem Content="Posición final del número obtenido del vector en la ejecución" Uid="8"/>
                <ComboBoxItem Content="Posición final del número obtenido del vector de la última ejecución" Uid="9"/>
                <ComboBoxItem Content="Cantidad total de cadenas de texto de la variable o vector de entrada" Uid="10"/>
                <ComboBoxItem Content="Cantidad total de números del vector o variable de entrada" Uid="11"/>
            </ComboBox>
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="10">Opción de esta lógica:</TextBlock>
            <ComboBox x:Name="opcionCondicion" Grid.Row="2" Grid.Column="1" Margin="10">
                <ComboBoxItem Content="Es igual a" Uid="1"/>
                <ComboBoxItem Content="Es distinto a" Uid="2"/>
                <ComboBoxItem Content="Contiene" Uid="3"/>
                <ComboBoxItem Content="Es parte de" Uid="11"/>
                <ComboBoxItem Content="No contiene" Uid="4"/>
                <ComboBoxItem Content="Empieza con" Uid="5"/>
                <ComboBoxItem Content="Termina con" Uid="6"/>
                <ComboBoxItem Content="Mayor que" Uid="7"/>
                <ComboBoxItem Content="Menor que" Uid="8"/>
                <ComboBoxItem Content="Mayor o igual que" Uid="9"/>
                <ComboBoxItem Content="Menor o igual que" Uid="10"/>
            </ComboBox>

            <TextBlock x:Name="textoElementoValores" Grid.Row="3" Grid.Column="0" Margin="10" >Elemento relacionado a valores:</TextBlock>
            <ComboBox x:Name="elementoRelacionadoValores" Grid.Row="3" Grid.Column="1" Margin="10"  SelectionChanged="elementoBusquedaRelacionadoCondicion_SelectionChanged">
                <ComboBoxItem Content="Cantidad de cadenas de texto obtenidas" Uid="1"/>
                <ComboBoxItem Content="Cantidad de números obtenidos del vector" Uid="2"/>
                <ComboBoxItem Content="Cantidad de cadenas de texto obtenidas de la última ejecución" Uid="3"/>
                <ComboBoxItem Content="Cantidad de números obtenidos del vector de la última ejecución" Uid="4"/>
                <ComboBoxItem Content="Posición del número obtenido del vector en la ejecución" Uid="6"/>
                <ComboBoxItem Content="Posición del número obtenido del vector en la última ejecución" Uid="7"/>
                <ComboBoxItem Content="Posición final del número obtenido del vector en la ejecución" Uid="8"/>
                <ComboBoxItem Content="Posición final del número obtenido del vector de la última ejecución" Uid="9"/>
                <ComboBoxItem Content="Cantidad total de cadenas de texto de la variable o vector de entrada" Uid="10"/>
                <ComboBoxItem Content="Cantidad total de números de la variable o vector de entrada" Uid="11"/>
                <ComboBoxItem Content="Valor fijo" Uid="5"/>                
            </ComboBox>

            <TextBlock x:Name="textoValoresCondicion" Grid.Row="4" Grid.Column="0" Margin="10" Visibility="Collapsed">Valores de lógica:</TextBlock>
            <TextBox x:Name="valoresRelacinadosCondicion" Grid.Row="4" Grid.Column="1" Margin="10" Visibility="Collapsed"></TextBox>

            <TextBlock Grid.Row="5" Grid.Column="0" Margin="10">Conector con la lógica anterior:</TextBlock>
            <ComboBox x:Name="conectorCondicion" Grid.Row="5" Grid.Column="1" Margin="10" SelectionChanged="conectorCondicion_SelectionChanged">
                <ComboBoxItem Content="Inicio de condiciones" Uid="1"/>
                <ComboBoxItem Content="Y" Uid="2"/>
                <ComboBoxItem Content="O" Uid="3"/>
            </ComboBox>
            <CheckBox x:Name="conectorO_Excluyente" VerticalContentAlignment="Center" Margin="10" Padding="5" Grid.Row="6" Grid.Column="1" Visibility="Collapsed">Conector excluyente. Esto implica que ninguna de las lógicas anteriores con el mismo conector deben cumplirse.</CheckBox>
            
            <TextBlock Grid.Row="7" Grid.Column="0" Margin="10">Cantidad de veces que se cumple la lógica:</TextBlock>
            <Grid Grid.Row="7" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <ComboBox x:Name="opcionCantidadNumerosCumplenCondicion" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" SelectionChanged="opcionCantidadNumerosCumplenCondicion_SelectionChanged">
                    <ComboBoxItem Content="Al menos 1" Uid="1" IsSelected="True"/>
                    <ComboBoxItem Content="Todos" Uid="2"/>
                    <ComboBoxItem Content="Cantidad determinada" Uid="3"/>
                </ComboBox>

                <ComboBox x:Name="opcionCantidadDeterminadaNumerosCumplenCondicion" Visibility="Collapsed" Grid.Row="1" Grid.Column="0" Margin="10">
                    <ComboBoxItem Content="Al menos" Uid="1" IsSelected="True"/>
                    <ComboBoxItem Content="Como máximo" Uid="2"/>
                    <ComboBoxItem Content="Exactamente" Uid="3"/>
                </ComboBox>

                <TextBox x:Name="cantidadNumerosCumplenCondicion" Visibility="Collapsed" Text="2" Margin="10" Grid.Row="1" Grid.Column="1" MinWidth="70" TextChanged="cantidadNumerosCumplenCondicion_TextChanged"></TextBox>
            </Grid>

            <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar lógica</Button>
                <Button x:Name="cancelar" Grid.Row="0" Grid.Column="1" Margin="10" Click="cancelar_Click">Cancelar</Button>
            </Grid>

        </Grid>
    </ScrollViewer>
</Window>
