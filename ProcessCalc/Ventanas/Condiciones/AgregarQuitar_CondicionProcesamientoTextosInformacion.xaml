<Window x:Class="ProcessCalc.Ventanas.AgregarQuitar_CondicionProcesamientoTextosInformacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        xmlns:opc="clr-namespace:ProcessCalc.Controles.TextosInformacion"
        mc:Ignorable="d"
        Title="Definir condición de lógica de cadenas de texto" Height="450" Width="800" WindowState="Maximized" Loaded="Window_Loaded" >
    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Margin="10" Padding="10" VerticalAlignment="Center">Tipo de lógica:</TextBlock>
            <ComboBox x:Name="opcionTipoCondicion" Grid.Row="0" Grid.Column="1" Margin="10" VerticalAlignment="Center" SelectionChanged="opcionTipoCondicion_SelectionChanged">
                <ComboBoxItem Content="Insertar cadenas de texto existentes" Uid="1"/>
                <ComboBoxItem Content="Editar/reemplazar cadenas de texto" Uid="2"/>
                <ComboBoxItem Content="Quitar cadenas de texto" Uid="3"/>
                <ComboBoxItem Content="Seguir ejecutando esta lógica según condiciones en las números" Uid="4"/>
                <ComboBoxItem Content="Detener la ejecución de esta lógica según condiciones en los números" Uid="5"/>
            </ComboBox>

            <TextBlock x:Name="textoOpcionTipoElemento" Grid.Row="1" Grid.Column="0" Margin="10" Padding="10" VerticalAlignment="Center">Elemento de lógica desde:</TextBlock>
            <ComboBox x:Name="opcionTipoElemento" Grid.Row="1" Grid.Column="1" Margin="10" VerticalAlignment="Center" SelectionChanged="opcionTipoElemento_SelectionChanged">
                <ComboBoxItem Content="Variable o vector" Uid="1"/>
                <ComboBoxItem Content="Variable o vector retornados" Uid="2"/>
                <ComboBoxItem Content="Variables o vectores y variables o vectores retornados" Uid="3"/>
            </ComboBox>

            <TextBlock x:Name="textoOpcionOperandos" Visibility="Collapsed" Grid.Row="2" Grid.Column="0" Margin="10" Padding="10" VerticalAlignment="Center">Realizar acción de esta lógica en:</TextBlock>
            <StackPanel x:Name="opcionOperandos" Visibility="Collapsed" Grid.Row="2" Grid.Column="1" Margin="10" VerticalAlignment="Center"></StackPanel>

            <TextBlock Grid.Row="3" Grid.Column="0" Margin="10" Padding="10" VerticalAlignment="Center">Condiciones a cumplir:</TextBlock>
            <opc:OpcionCondiciones_ImplicacionTextosInformacion x:Name="condicionesFiltroCantidades" Margin="10" Grid.Row="3" Grid.Column="1" VerticalContentAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="300" MinWidth="200"></opc:OpcionCondiciones_ImplicacionTextosInformacion>

            <TextBlock x:Name="textoOpcionTipoElementoDesde" Grid.Row="4" Grid.Column="0" Margin="10" Padding="10" Visibility="Collapsed" VerticalAlignment="Center">Elemento donde insertar o editar:</TextBlock>
            <ComboBox x:Name="opcionTipoElementoDesde" Grid.Row="4" Grid.Column="1" Margin="10" Visibility="Collapsed" VerticalAlignment="Center" SelectionChanged="opcionTipoElementoAccion_SelectionChanged" >
                <ComboBoxItem Content="Variable o vector" Uid="1"/>
                <ComboBoxItem Content="Variable o vector retornados" Uid="2"/>
                <ComboBoxItem Content="Variables o vectores y variables o vectores retornados" Uid="3"/>
            </ComboBox>

            <TextBlock x:Name="textoOpcionOperandosDesde" Visibility="Collapsed" Grid.Row="5" Grid.Column="0" Margin="10" Padding="10" VerticalAlignment="Center">Variables o vectores donde:</TextBlock>
            <StackPanel x:Name="opcionOperandosDesde" Visibility="Collapsed" Grid.Row="5" Grid.Column="1" Margin="10" VerticalAlignment="Center"></StackPanel>

            <TextBlock x:Name="textoUbicacionElementoAccion" Grid.Row="6" Grid.Column="0" Margin="10" Padding="10" Visibility="Collapsed" VerticalAlignment="Center">Insertar o reemplazar en :</TextBlock>
            
            <ComboBox x:Name="opcionUbicacionElementoAccion" Grid.Row="6" Grid.Column="1" Margin="10" Visibility="Collapsed" VerticalAlignment="Center" >
                <ComboBoxItem Content="Número del vector en la ejecución" Uid="1"/>
                <ComboBoxItem Content="Número anterior del vector en la ejecución" Uid="2"/>
                <ComboBoxItem Content="Número siguiente del vector en la ejecución" Uid="3"/>
            </ComboBox>

            <TextBlock x:Name="textoOpcionUbicacionAccion_Insertar" Grid.Row="7" Grid.Column="0" Margin="10" Padding="10" Visibility="Collapsed" VerticalAlignment="Center">Insertar o reemplazar con :</TextBlock>
            <ComboBox x:Name="opcionUbicacionAccion_Insertar" Grid.Row="7" Grid.Column="1" Margin="10" Visibility="Collapsed" VerticalAlignment="Center" SelectionChanged="opcionUbicacionAccion_Insertar_SelectionChanged" >
                <ComboBoxItem Content="Número del vector en la ejecución" Uid="1"/>
                <ComboBoxItem Content="Número anterior del vector en la ejecución" Uid="2"/>
                <ComboBoxItem Content="Número siguiente del vector en la ejecución" Uid="3"/>
                <ComboBoxItem Content="Valor fijo" Uid="9"/>
            </ComboBox>

            <TextBox x:Name="valorFijo" Grid.Row="8" Grid.Column="1" Margin="10" Visibility="Collapsed" VerticalAlignment="Center" ></TextBox>

            <Grid x:Name="opcionesOperandoNumeros" Visibility="Collapsed" Grid.Column="0" Grid.Row="9" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition></ColumnDefinition>
                    <ColumnDefinition></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="opcionOperandosFiltroCantidades" Grid.Column="0" Margin="19" Padding="10" VerticalContentAlignment="Center" VerticalAlignment="Center">Procesar por cada variable o vector (como un todo)</CheckBox>
                <CheckBox x:Name="opcionNumerosFiltroCantidades" Grid.Column="1" Margin="19" Padding="10" VerticalContentAlignment="Center" VerticalAlignment="Center">Procesar por cada número de la variable o vector</CheckBox>

            </Grid>

            <TextBlock Grid.Column="0" Grid.Row="10" Margin="10" Padding="10" VerticalAlignment="Center">Aplicar:</TextBlock>
            <Grid Grid.Column="1" Grid.Row="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="opcionAplicarProcesamientoSinCondiciones" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="0"  Margin="10" VerticalAlignment="Center">Aplicar los efectos de esta lógica cuando la variable o vector no esté en esta lógica.</CheckBox>
                <CheckBox x:Name="opcionAplicarProcesamientoTexto_ACantidadesInsertadasProcesamientoCantidades" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="1"  Margin="10" VerticalAlignment="Center" Checked="opcionAplicarProcesamientoTexto_ACantidadesInsertadasProcesamientoCantidades_Checked">
                    <TextBlock>Incluir y aplicar los efectos de estas condiciones a las cantidades del operando
                    <LineBreak></LineBreak> que sean procesadas por este procesamiento de cadenas de texto de cantidades.
                    </TextBlock></CheckBox>
                <CheckBox x:Name="opcionAplicarProcesamientoTexto_SoloACantidadesInsertadasProcesamientoCantidades" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="2"  Margin="10" VerticalAlignment="Center" Checked="opcionAplicarProcesamientoTexto_SoloACantidadesInsertadasProcesamientoCantidades_Checked">
                    <TextBlock>Aplicar los efectos de estas condiciones solo a las cantidades del operando
    <LineBreak></LineBreak> que sean procesadas por este procesamiento de cadenas de texto de cantidades.
                    </TextBlock>
                </CheckBox>
                <CheckBox x:Name="opcionReiniciarAcumulacion" Visibility="Collapsed" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="3" Margin="10" VerticalAlignment="Center" >Reiniciar a cero la acumulación por filas del vector.</CheckBox>
                <CheckBox x:Name="opcionProcesarCadenasTexto_SinCumplirCondiciones_CadenasTextos" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="4" Margin="10" VerticalAlignment="Center">Procesar las cadenas de texto aunque no cumplan con la condición, pero sí en general</CheckBox>
            </Grid>

            <Button x:Name="Cancelar" Grid.Row="11" Grid.Column="0" Margin="10" Padding="10" MaxWidth="100" Click="Cancelar_Click">Cancelar</Button>
            <Button x:Name="Guardar" Grid.Row="11" Grid.Column="1" Margin="10" Padding="10" MaxWidth="100" Click="Guardar_Click">Guardar lógica</Button>
        </Grid>
    </ScrollViewer>
</Window>
