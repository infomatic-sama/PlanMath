<Window x:Class="ProcessCalc.Ventanas.AgregarQuitar_CondicionConjuntoBusquedas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProcessCalc.Ventanas"
        mc:Ignorable="d"
        Title="Condición para lógicas de búsquedas" Height="450" Width="800" SizeToContent="WidthAndHeight" Loaded="Window_Loaded" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <ScrollViewer CanContentScroll="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
            <ColumnDefinition Width="Auto"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="10">Lógica de búsqueda relacionada a condición:</TextBlock>
        <ComboBox x:Name="busquedaRelacionadaCondicion" Grid.Row="0" Grid.Column="1" Margin="10"></ComboBox>
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="10">Elemento de Lógica de búsqueda relacionado a condición:</TextBlock>
        <ComboBox x:Name="elementoBusquedaRelacionadoCondicion" Grid.Row="1" Grid.Column="1" Margin="10" SelectionChanged="elementoBusquedaRelacionadoCondicion_SelectionChanged">
            <ComboBoxItem Content="Textos de información a asignar" Uid="1"/>
            <ComboBoxItem Content="Cantidad de textos de información a asignar" Uid="2"/>
            <ComboBoxItem Content="Números encontrados" Uid="3"/>
            <ComboBoxItem Content="Cantidad de números encontrados" Uid="4"/>
            <ComboBoxItem x:Name="opcionCantidadBusquedasConjunto" Content="Cantidad de búsquedas de conjunto realizadas" Uid="5"/>
            <ComboBoxItem x:Name="opcionTextosBusqueda" Visibility="Collapsed" Content="Texto de búsqueda encontrado" Uid="6"/>
        </ComboBox>
        <TextBlock Grid.Row="2" Grid.Column="0" Margin="10">Opción de condición:</TextBlock>
        <ComboBox x:Name="opcionCondicion" Grid.Row="2" Grid.Column="1" Margin="10" SelectionChanged="opcionCondicion_SelectionChanged">
            <ComboBoxItem x:Name="opcionTextoBusquedaCoincida" Visibility="Collapsed" Content="Coincida" Uid="11"/>
            <ComboBoxItem x:Name="opcionTextoBusquedaNoCoincida" Visibility="Collapsed" Content="No coincida" Uid="12"/>
            <ComboBoxItem Content="Es igual a" Uid="1"/>
            <ComboBoxItem Content="Es distinto a" Uid="2"/>
            <ComboBoxItem Content="Contiene" Uid="3"/>
            <ComboBoxItem Content="No contiene" Uid="4"/>
            <ComboBoxItem Content="Empieza con" Uid="5"/>
            <ComboBoxItem Content="Termina con" Uid="6"/>
            <ComboBoxItem Content="Mayor que" Uid="7"/>
            <ComboBoxItem Content="Menor que" Uid="8"/>
            <ComboBoxItem Content="Mayor o igual que" Uid="9"/>
            <ComboBoxItem Content="Menor o igual que" Uid="10"/>
        </ComboBox>
        <TextBlock x:Name="textoValoresCondicion" Grid.Row="3" Grid.Column="0" Margin="10">Valores de condición:</TextBlock>
        <TextBox x:Name="valoresRelacinadosCondicion" Grid.Row="3" Grid.Column="1" Margin="10"></TextBox>
        <TextBlock Grid.Row="4" Grid.Column="0" Margin="10">Conector con la condición anterior:</TextBlock>
        <ComboBox x:Name="conectorCondicion" Grid.Row="4" Grid.Column="1" Margin="10" SelectionChanged="conectorCondicion_SelectionChanged">
            <ComboBoxItem Content="Inicio de condiciones" Uid="1"/>
            <ComboBoxItem Content="Y" Uid="2"/>
            <ComboBoxItem Content="O" Uid="3"/>
        </ComboBox>
            <CheckBox x:Name="conectorO_Excluyente" VerticalContentAlignment="Center" Margin="10" Padding="5" Grid.Row="5" Grid.Column="1" Visibility="Collapsed">Conector excluyente. Esto implica que ninguna de las condiciones anteriores con el mismo conector deben cumplirse.</CheckBox>
            
        <TextBlock Grid.Row="6" Grid.Column="0" Margin="10">Cantidad de veces que se cumple la condición:</TextBlock>
        <Grid Grid.Row="6" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="opcionCantidadNumerosCumplenCondicion" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" SelectionChanged="opcionCantidadNumerosCumplenCondicion_SelectionChanged">
                <ComboBoxItem Content="Al menos 1" Uid="1" IsSelected="True"/>
                <ComboBoxItem Content="Todos" Uid="2"/>
                <ComboBoxItem Content="Cantidad determinada" Uid="3"/>
            </ComboBox>

            <ComboBox x:Name="opcionCantidadDeterminadaNumerosCumplenCondicion" Visibility="Collapsed" Grid.Row="1" Grid.Column="0" Margin="10">
                <ComboBoxItem Content="Al menos" Uid="1" IsSelected="True"/>
                <ComboBoxItem Content="Como máximo" Uid="2"/>
                <ComboBoxItem Content="Exactamente" Uid="3"/>
            </ComboBox>

            <TextBox x:Name="cantidadNumerosCumplenCondicion" Visibility="Collapsed" Text="2" Margin="10" Grid.Row="1" Grid.Column="1" MinWidth="70" TextChanged="cantidadNumerosCumplenCondicion_TextChanged"></TextBox>
        </Grid>
        
        <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar condición</Button>
            <Button x:Name="cancelar" Grid.Row="0" Grid.Column="1" Margin="10" Click="cancelar_Click">Cancelar</Button>
        </Grid>
        
    </Grid>
    </ScrollViewer>
</Window>
