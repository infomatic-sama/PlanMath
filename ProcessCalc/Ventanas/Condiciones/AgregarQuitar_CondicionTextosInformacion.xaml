                    <ComboBoxItem Content="Posición actual del número del vector en la ejecución" Uid="1"/>
                    <ComboBoxItem Content="Posición anterior del número del vector en la ejecución" Uid="3"/>
                    <ComboBoxItem Content="Posición siguiente del número del vector en la ejecución" Uid="4"/>
                    <ComboBoxItem Content="Posición primera del número del vector en la ejecución" Uid="8"/>
                    <ComboBoxItem Content="Posición segunda del número del vector en la ejecución" Uid="9"/>
                    <ComboBoxItem Content="Posición en la mitad del número del vector en la ejecución" Uid="10"/>
                    <ComboBoxItem Content="Posición penúltima del número del vector en la ejecución" Uid="11"/>
                    <ComboBoxItem Content="Posición última del número del vector en la ejecución" Uid="12"/>
                    <ComboBoxItem Content="El conjunto de números de la variable o vector hasta la posición en la ejecución" Uid="6"/>
                    <ComboBoxItem Content="El conjunto de números de la variable o vector en la ejecución" Uid="2"/>
                    <ComboBoxItem Content="El conjunto total de números de la variable o vector (incluyendo que no cumplen las condiciones)" Uid="5"/>
                    <ComboBoxItem Content="El conjunto total de números de la variable o vector (incluyendo que no cumplen las condiciones) hasta la posición en la ejecución" Uid="7"/>
                </ComboBox>

                <TextBlock x:Name="textoOpcionCantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada" Grid.Row="2" Grid.Column="0" Margin="10" Visibility="Collapsed">Cantidad de números del vector que cumplen la condición si/entonces:</TextBlock>
                <Grid x:Name="opcionesCantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <CheckBox x:Name="opcionCantidadNumeros_PorElemento_Valores" Visibility="Collapsed" Grid.Row="0" Grid.Column="0">Considerar por cada número</CheckBox>

                    <ComboBox x:Name="opcionCantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada" Grid.Row="1" Grid.Column="0" Margin="10" SelectionChanged="opcionCantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada_SelectionChanged" >
                        <ComboBoxItem Content="Al menos 1" Uid="1" IsSelected="True"/>
                        <ComboBoxItem Content="Todos" Uid="2"/>
                        <ComboBoxItem Content="Cantidad determinada" Uid="3"/>
                    </ComboBox>

                    <ComboBox x:Name="opcionCantidadDeterminadaSubNumerosCumplenCondicion_Valores_OperacionEntrada" Visibility="Collapsed" Grid.Row="2" Grid.Column="0" Margin="10">
                        <ComboBoxItem Content="Al menos" Uid="1" IsSelected="True"/>
                        <ComboBoxItem Content="Como máximo" Uid="2"/>
                        <ComboBoxItem Content="Exactamente" Uid="3"/>
                    </ComboBox>

                    <ComboBox x:Name="opcionTipoCantidadDeterminadaSubNumerosCumplenCondicion_Valores_OperacionEntrada" Visibility="Collapsed" Grid.Row="2" Grid.Column="1" Margin="10" SelectionChanged="opcionTipoCantidadDeterminadaSubNumerosCumplenCondicion_Valores_OperacionEntrada_SelectionChanged">
                        <ComboBoxItem Content="Cantidad fija" Uid="1" IsSelected="True"/>
                        <ComboBoxItem Content="Números de la variable o vector de la condición, que cumplen la condición si/entonces" Uid="2"/>
                        <ComboBoxItem Content="Números de la variable o vector de los valores, que cumplen la condición si/entonces" Uid="3"/>
                        <ComboBoxItem Content="Números de la variable o vector de la condición" Uid="4"/>
                        <ComboBoxItem Content="Números de la variable o vector de los valores" Uid="5"/>
                    </ComboBox>

                    <TextBox x:Name="cantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada" Visibility="Collapsed" Text="2" Margin="10" Grid.Row="2" Grid.Column="2" MinWidth="70" ></TextBox>

                    <CheckBox x:Name="opcionSaldoCantidadSubNumerosCumplenCondicion_Valores_OperacionEntrada" Margin="10" Grid.Row="3" Grid.ColumnSpan="3" Grid.Column="0">Calcular saldo de cantidades (números que cumplen la condicion menos números que no cumplen)</CheckBox>
                </Grid>

                <CheckBox x:Name="opcionConsiderarOperandoValores_CantidadesAsignacion_LogicaImplicaciones" Grid.Row="3" Grid.Column="0" Margin="10">Considerar las cantidades de este operando valores, para la asignación de cadenas de texto de lógicas de implicaciones</CheckBox>

            </Grid>

            <TextBlock x:Name="textoSubelementoElementoRelacionadoCondicion_Valores" Grid.Row="7" Grid.Column="0" Margin="10" Visibility="Collapsed">Opción de la variable o vector relacionado a valores:</TextBlock>
            <ComboBox x:Name="subelementoElementoRelacionadoCondicion_Valores" Grid.Row="7" Grid.Column="1" Margin="10" Visibility="Collapsed">
                <ComboBoxItem Content="Números en la variable o vector" Uid="1"/>
                <ComboBoxItem Content="Cantidad de números en la variable o vector" Uid="2"/>
                <ComboBoxItem Content="Posiciones de números en la variable o vector" Uid="3"/>
                <ComboBoxItem Content="Cantidad de cadenas de texto en el número de la variable o vector" Uid="7"/>
                <ComboBoxItem Content="Posiciones del operando del número de la variable o vector" Uid="8"/>
            </ComboBox>

            <TextBlock x:Name="textoContenedorTextoBusqueda" Margin="10" Grid.Row="10" Grid.Column="0" Visibility="Collapsed">Cadenas de texto de lógica de búsqueda:</TextBlock>
            <ScrollViewer x:Name="contenedorTextoBusqueda" Grid.Row="10" Grid.Column="1" Visibility="Collapsed">
                <Controles:TextoEnArchivo x:Name="textoBusqueda" />
            </ScrollViewer>

            <TextBlock Grid.Row="11" Grid.Column="0" Margin="10">Conector con la condición si/entonces anterior:</TextBlock>
        <ComboBox x:Name="conectorCondicion" Grid.Row="11" Grid.Column="1" Margin="10" SelectionChanged="conectorCondicion_SelectionChanged">
            <ComboBoxItem Content="Inicio de condiciones" Uid="1"/>
            <ComboBoxItem Content="Y" Uid="2"/>
            <ComboBoxItem Content="O" Uid="3"/>
        </ComboBox>
            <CheckBox x:Name="conectorO_Excluyente" VerticalContentAlignment="Center" Margin="10" Padding="5" Grid.Row="12" Grid.Column="1" Visibility="Collapsed">Conector excluyente. Esto implica que ninguna de las condiciones si/entonces anteriores con el mismo conector deben cumplirse.</CheckBox>

        <TextBlock Grid.Row="13" Grid.Column="0" Margin="10">Cantidad de veces que se cumple la condición si/entonces:</TextBlock>
        <Grid Grid.Row="13" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="opcionCantidadNumerosCumplenCondicion" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="10" SelectionChanged="opcionCantidadNumerosCumplenCondicion_SelectionChanged">
                <ComboBoxItem Content="Al menos 1" Uid="1" IsSelected="True"/>
                <ComboBoxItem Content="Todos" Uid="2"/>
                <ComboBoxItem Content="Cantidad determinada" Uid="3"/>
            </ComboBox>

            <ComboBox x:Name="opcionCantidadDeterminadaNumerosCumplenCondicion" Visibility="Collapsed" Grid.Row="1" Grid.Column="0" Margin="10">
                <ComboBoxItem Content="Al menos" Uid="1" IsSelected="True"/>
                <ComboBoxItem Content="Como máximo" Uid="2"/>
                <ComboBoxItem Content="Exactamente" Uid="3"/>
            </ComboBox>

            <TextBox x:Name="cantidadNumerosCumplenCondicion" Visibility="Collapsed" Text="2" Margin="10" Grid.Row="1" Grid.Column="1" MinWidth="70" TextChanged="cantidadNumerosCumplenCondicion_TextChanged"></TextBox>

            <CheckBox x:Name="opcionSaldoCantidadNumerosCumplenCondicion" Margin="10" Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0">Calcular saldo de cantidades (números que cumplen la condicion menos números que no cumplen)</CheckBox>
        </Grid>

            <CheckBox x:Name="opcionQuitarEspaciosTemporalmente_CadenaCondicion" Grid.Row="14" Grid.Column="1" Margin="10" VerticalAlignment="Center">Quitar espacios de la cadena de texto sólo para aplicar esta condición</CheckBox>


            <CheckBox x:Name="opcionNegarCondicion" Grid.Row="15" Grid.Column="1" Margin="10" VerticalAlignment="Center">Negar la condición si/entonces para que se cumpla</CheckBox>

        <CheckBox x:Name="opcionAplicarCondicionFinalNumerosOperando" Grid.Row="16" Grid.Column="1" Margin="10" VerticalAlignment="Center">Seguir aplicando la condición si/entonces cuando se llegue al final de los números de la variable o vector</CheckBox>

        <CheckBox x:Name="opcionAplicarCondicionFinalNumerosOperandoValores" Grid.Row="17" Grid.Column="1" Margin="10" VerticalAlignment="Center">Seguir aplicando la condición si/entonces cuando se llegue al final de los números de la variable o vector de valores</CheckBox>

            <CheckBox x:Name="opcionAplicarReiniciarFinalNumerosOperando" Grid.Row="18" Grid.Column="1" Margin="10" VerticalAlignment="Center">Reiniciar la posición cuando se llegue al final de los números de la variable o vector</CheckBox>

            <CheckBox x:Name="opcionAplicarReiniciarFinalNumerosOperando_Valores" Grid.Row="19" Grid.Column="1" Margin="10" VerticalAlignment="Center">Reiniciar la posición cuando se llegue al final de los números de la variable o vector de valores</CheckBox>

            <CheckBox x:Name="opcionCumpleCondicion_ElementoSinCantidades" Grid.Row="20" Grid.Column="1" Margin="10" VerticalAlignment="Center">Hacer que la condición si/entonces se cumpla si la variable o vector de la condición no tiene números y si el número no tiene cadenas de texto</CheckBox>
            <CheckBox x:Name="opcionCumpleCondicion_ElementoValores_SinCantidades" Grid.Row="21" Grid.Column="1" Margin="10" VerticalAlignment="Center">Hacer que la condición si/entonces se cumpla si la variable o vector de valores no tiene números y si el número no tiene cadenas de texto</CheckBox>

            <TextBlock Grid.Row="22" Grid.Column="0" Margin="10" Padding="5" VerticalAlignment="Center">Efectos de la condición si/entonces:</TextBlock>
            <Grid Grid.Row="22" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <CheckBox x:Name="opcionConsiderarOperandoCondicion_SiCumple" VerticalContentAlignment="Center" Margin="10" Grid.Row="0" Checked="opcionConsiderarOperandoCondicion_SiCumple_Checked" Unchecked="opcionConsiderarOperandoCondicion_SiCumple_Unchecked" >Considerar la variable o vector de esta condición si/entonces para aplicar sus efectos, si cumple la condición.</CheckBox>
                <CheckBox x:Name="opcionConsiderarCondicionesHijas" VerticalContentAlignment="Center" Margin="10" Grid.Row="1">Considerar incluir las condiciones si/entonces contenidas en esta condición en la verificación de la variable o vector.</CheckBox>
            </Grid>
            
            <Grid Grid.Row="23" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="agregarCondicion" Grid.Row="0" Grid.Column="0" Margin="10" Click="agregarCondicion_Click">Agregar condición si/entonces</Button>
            <Button x:Name="cancelar" Grid.Row="0" Grid.Column="1" Margin="10" Click="cancelar_Click">Cancelar</Button>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
